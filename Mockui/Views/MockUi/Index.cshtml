@{
    ViewData["Title"] = "Mock UI Landing";
}

<link rel="stylesheet" href="~/mockui/css/mock-ui.css" asp-append-version="true" />

<div class="mock-entry-page">
    <h1>Mock UI Landing</h1>
    <p class="mock-muted">Cross-role navigation hub aligned with the revised role page inventory and deeper drill-down expectations.</p>
    <div class="mock-alert info">
        <strong>Scope emphasis:</strong> in every role flow, listed properties and units should be reachable through dedicated details pages.
        Use these entry points to validate list-to-details navigation consistency.
    </div>

    <div class="mock-grid mock-grid-3">
        <section class="mock-card">
            <h2>Management</h2>
            <p>Operational control center for lifecycle execution, property/unit drill-down, and partner coordination.</p>
            <a class="mock-btn" asp-area="Management" asp-controller="Dashboard" asp-action="Index">Open dashboard</a>
            <p class="mock-section-note">Expanded scope pages</p>
            <ul class="mock-link-list">
                <li><a asp-area="Management" asp-controller="Tickets" asp-action="Index">Tickets</a></li>
                <li><a asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1001">Ticket details</a></li>
                <li><a asp-area="Management" asp-controller="Tickets" asp-action="Activity" asp-route-id="1001">Ticket work log &amp; activity</a></li>
                <li><a asp-area="Management" asp-controller="Tickets" asp-action="Scheduling" asp-route-id="1001">Ticket assignment &amp; scheduling</a></li>
                <li><a asp-area="Management" asp-controller="Properties" asp-action="Index">Properties</a></li>
                <li><a asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="201">Property details</a></li>
                <li><a asp-area="Management" asp-controller="Properties" asp-action="Units" asp-route-id="201">Property units list</a></li>
                <li><a asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="501">Unit details</a></li>
                <li><a asp-area="Management" asp-controller="Customers" asp-action="Index">Customers</a></li>
                <li><a asp-area="Management" asp-controller="Customers" asp-action="Details" asp-route-id="301">Customer details</a></li>
                <li><a asp-area="Management" asp-controller="Vendors" asp-action="Index">Vendors</a></li>
                <li><a asp-area="Management" asp-controller="Vendors" asp-action="Details" asp-route-id="401">Vendor details</a></li>
            </ul>
            <ol class="mock-path-list">
                <li>Dashboard → Properties → Property details → Unit details</li>
                <li>Dashboard → Tickets → Ticket details → Related property/unit context</li>
            </ol>
        </section>

        <section class="mock-card">
            <h2>Customer Representative</h2>
            <p>Portfolio visibility and collaboration flow derived from management structure with read-focused detail depth.</p>
            <a class="mock-btn" asp-area="Customer" asp-controller="Dashboard" asp-action="Index">Open dashboard</a>
            <p class="mock-section-note">Expanded scope pages</p>
            <ul class="mock-link-list">
                <li><a asp-area="Customer" asp-controller="Tickets" asp-action="Index">Tickets</a></li>
                <li><a asp-area="Customer" asp-controller="Tickets" asp-action="Details" asp-route-id="504">Ticket details</a></li>
                <li><a asp-area="Customer" asp-controller="Properties" asp-action="Index">Properties</a></li>
                <li><a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="201">Property details</a></li>
                <li><a asp-area="Customer" asp-controller="Units" asp-action="Index" asp-route-propertyId="201">Units overview</a></li>
                <li><a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="501">Unit details</a></li>
                <li><a asp-area="Customer" asp-controller="Updates" asp-action="Index">Updates</a></li>
                <li><a asp-area="Customer" asp-controller="Profile" asp-action="Index">Profile</a></li>
            </ul>
            <ol class="mock-path-list">
                <li>Dashboard → Properties → Property details → Unit details</li>
                <li>Dashboard → Tickets → Ticket details → Related unit context</li>
            </ol>
        </section>

        <section class="mock-card">
            <h2>Resident</h2>
            <p>Personal workspace for multi-unit residents with unit-scoped pages and parent property drill-down.</p>
            <a class="mock-btn" asp-area="Resident" asp-controller="Dashboard" asp-action="Index">Open dashboard</a>
            <p class="mock-section-note">Expanded scope pages</p>
            <ul class="mock-link-list">
                <li><a asp-area="Resident" asp-controller="Tickets" asp-action="MyTickets">My Tickets</a></li>
                <li><a asp-area="Resident" asp-controller="Tickets" asp-action="Details" asp-route-id="701">Ticket details</a></li>
                <li><a asp-area="Resident" asp-controller="Tickets" asp-action="NewTicket">New Ticket</a></li>
                <li><a asp-area="Resident" asp-controller="Units" asp-action="Index">My Units</a></li>
                <li><a asp-area="Resident" asp-controller="Units" asp-action="Details" asp-route-id="301">Unit details</a></li>
                <li><a asp-area="Resident" asp-controller="Properties" asp-action="Details" asp-route-id="201">Parent property details</a></li>
                <li><a asp-area="Resident" asp-controller="Support" asp-action="Index">Support</a></li>
                <li><a asp-area="Resident" asp-controller="Profile" asp-action="Index">Profile</a></li>
            </ul>
            <ol class="mock-path-list">
                <li>Dashboard (aggregated resident view) → My units → Unit details</li>
                <li>My tickets → Ticket details → Unit details → Parent property details</li>
            </ol>
        </section>
    </div>
</div>


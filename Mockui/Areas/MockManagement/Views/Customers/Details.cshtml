@{
    var customerId = (int?)ViewData["CustomerId"] ?? 301;
    ViewData["Title"] = $"Customer Details #{customerId}";
}

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Customer profile</h2>
        <ul class="mock-link-list">
            <li>Company: Nordic Housing Group</li>
            <li>Primary representative: Anna P.</li>
            <li>Technical representative: Märt K.</li>
            <li>Billing representative: Linda V.</li>
        </ul>
    </section>
    <section class="mock-card">
        <h2>Portfolio overview</h2>
        <ul class="mock-link-list">
            <li>Managed properties in portfolio: 5</li>
            <li>Open tickets: 14</li>
            <li>Awaiting closure confirmations: 3</li>
        </ul>
    </section>
</div>

<section class="mock-card">
    <h2>Linked objects</h2>
    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="201">Linked property details</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="501">Linked unit details</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1001">Linked ticket details</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Customers" asp-action="Index">Back to customers list</a>
    </div>
</section>


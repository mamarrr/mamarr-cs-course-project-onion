@{
    var propertyId = (int?)ViewData["PropertyId"] ?? 201;
    ViewData["Title"] = $"Property Details #{propertyId}";
}

<div class="mock-alert info">Property details are accessed from unit context and represent the selected unit's parent property.</div>

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Property profile</h2>
        <ul class="mock-link-list">
            <li>Name: Riverside 12</li>
            <li>Type: Apartment building</li>
            <li>Address: Riverside St 12, Tallinn</li>
            <li>Support desk: +372 600 0100</li>
        </ul>
    </section>
    <section class="mock-card">
        <h2>Resident-facing context</h2>
        <ul class="mock-link-list">
            <li>Resident-linked unit in this property: <a asp-area="Resident" asp-controller="Units" asp-action="Details" asp-route-id="301">Unit 18</a></li>
            <li>Related ticket: <a asp-area="Resident" asp-controller="Tickets" asp-action="Details" asp-route-id="701">#RT-701 Bathroom faucet drip</a></li>
            <li>More resident-linked units: <a asp-area="Resident" asp-controller="Units" asp-action="Index">Open My Units</a></li>
        </ul>
    </section>
</div>

<section class="mock-card">
    <h2>Navigation</h2>
    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Units" asp-action="Details" asp-route-id="301">Back to unit details</a>
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Units" asp-action="Index">Back to my units</a>
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Dashboard" asp-action="Index">Back to dashboard</a>
    </div>
</section>


@{
    var ticketId = (int?)ViewData["TicketId"] ?? 701;
    ViewData["Title"] = $"Ticket Details #{ticketId}";
}

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Ticket summary</h2>
        <ul class="mock-link-list">
            <li>Category: Plumbing</li>
            <li>Status: <span class="mock-badge">Scheduled</span></li>
            <li>Priority: <span class="mock-badge warning">Medium</span></li>
            <li>Updated: Today 09:45</li>
        </ul>
    </section>
    <section class="mock-card">
        <h2>Related unit and property</h2>
        <ul class="mock-link-list">
            <li>Unit: <a asp-area="Resident" asp-controller="Units" asp-action="Details" asp-route-id="301">Unit 18</a></li>
            <li>Parent property: <a asp-area="Resident" asp-controller="Properties" asp-action="Details" asp-route-id="201">Riverside 12</a></li>
            <li>All units: <a asp-area="Resident" asp-controller="Units" asp-action="Index">Open my units</a></li>
        </ul>
    </section>
</div>

<section class="mock-card">
    <h2>Issue details</h2>
    <p class="mock-muted">Slow leak under kitchen sink. Resident can provide access tomorrow after 13:00.</p>

    <h2>Activity timeline</h2>
    <ul class="mock-timeline">
        <li><strong>Created:</strong> Report submitted with image attachment.</li>
        <li><strong>Assigned:</strong> Vendor assigned and visit window proposed.</li>
        <li><strong>Scheduled:</strong> Visit confirmed for Tomorrow 14:00.</li>
    </ul>

    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Units" asp-action="Details" asp-route-id="301">Open related unit</a>
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Properties" asp-action="Details" asp-route-id="201">Open parent property</a>
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Tickets" asp-action="MyTickets">Back to my tickets</a>
    </div>
</section>


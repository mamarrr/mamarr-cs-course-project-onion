@{
    var ticketId = (int?)ViewData["TicketId"] ?? 504;
    ViewData["Title"] = $"Ticket Details #{ticketId}";
}

<div class="mock-alert info">Read-focused ticket detail view for customer representatives.</div>

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Ticket summary</h2>
        <ul class="mock-link-list">
            <li>Category: Electrical</li>
            <li>Status: <span class="mock-badge">In Progress</span></li>
            <li>Priority: <span class="mock-badge warning">Medium</span></li>
            <li>Last update: Today 10:20</li>
        </ul>
    </section>
    <section class="mock-card">
        <h2>Related context</h2>
        <ul class="mock-link-list">
            <li>Property: <a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="203">Harbor View 2</a></li>
            <li>Unit: <a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="503">Unit C-12</a></li>
            <li>Unit overview: <a asp-area="Customer" asp-controller="Units" asp-action="Index" asp-route-propertyId="203">All units for Harbor View 2</a></li>
        </ul>
    </section>
</div>

<section class="mock-card">
    <h2>Issue details</h2>
    <p class="mock-muted">Sensor intermittently fails during peak occupancy. Vendor replacement window confirmed for tomorrow.</p>

    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Updates" asp-action="Index">Add comment (mock)</a>
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Updates" asp-action="Index">Confirm resolution intent (mock)</a>
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Updates" asp-action="Index">Escalate concern intent (mock)</a>
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Tickets" asp-action="Index">Back to tickets</a>
    </div>
</section>


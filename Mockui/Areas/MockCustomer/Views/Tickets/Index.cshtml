@{
    ViewData["Title"] = "Customer Tickets";
}

<div class="mock-alert info">Static portfolio ticket list for status tracking and follow-up comments.</div>

<section class="mock-card">
    <h2>Portfolio tickets</h2>
    <table class="mock-table">
        <thead>
        <tr>
            <th>Ticket</th>
            <th>Property</th>
            <th>Unit</th>
            <th>Status</th>
            <th>Updated</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>#CT-504 Lobby door sensor</td>
            <td><a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="203">Harbor View 2</a></td>
            <td><a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="503">Unit C-12</a></td>
            <td><span class="mock-badge success">In Progress</span></td>
            <td>1h ago</td>
            <td>
                <a asp-area="Customer" asp-controller="Tickets" asp-action="Details" asp-route-id="504">Details</a>
            </td>
        </tr>
        <tr>
            <td>#CT-505 Basement humidity</td>
            <td><a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="202">Oak Street 5</a></td>
            <td><a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="502">Unit A-02</a></td>
            <td><span class="mock-badge">Scheduled</span></td>
            <td>3h ago</td>
            <td>
                <a asp-area="Customer" asp-controller="Tickets" asp-action="Details" asp-route-id="505">Details</a>
            </td>
        </tr>
        <tr>
            <td>#CT-506 Corridor lighting</td>
            <td><a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="201">Riverside 12</a></td>
            <td><a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="501">Unit 5B</a></td>
            <td><span class="mock-badge warning">Completed</span></td>
            <td>Yesterday</td>
            <td>
                <a asp-area="Customer" asp-controller="Tickets" asp-action="Details" asp-route-id="506">Details</a>
            </td>
        </tr>
        </tbody>
    </table>

    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Properties" asp-action="Index">Open properties list</a>
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Units" asp-action="Index">Open units overview</a>
    </div>
</section>


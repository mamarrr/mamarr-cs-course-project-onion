@{
    ViewData["Title"] = "Customer Properties";
}

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Property coverage</h2>
        <ul class="mock-link-list">
            <li>Total properties: 18</li>
            <li>Active tickets this week: 13</li>
            <li>Resolved this month: 44</li>
        </ul>
    </section>
    <section class="mock-card">
        <h2>Risk summary</h2>
        <p class="mock-muted">Placeholder for SLA risk indicators per property.</p>
        <span class="mock-badge danger">2 properties require escalation</span>
    </section>
</div>

<section class="mock-card">
    <h2>Property list</h2>
    <table class="mock-table">
        <thead>
        <tr>
            <th>Property</th>
            <th>Type</th>
            <th>Open tickets</th>
            <th>Units</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>Riverside 12</td>
            <td>Apartment building</td>
            <td>6</td>
            <td>34</td>
            <td>
                <a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="201">Details</a> |
                <a asp-area="Customer" asp-controller="Units" asp-action="Index" asp-route-propertyId="201">Units</a> |
                <a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="501">Unit details</a>
            </td>
        </tr>
        <tr>
            <td>Oak Street 5</td>
            <td>Apartment building</td>
            <td>5</td>
            <td>21</td>
            <td>
                <a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="202">Details</a> |
                <a asp-area="Customer" asp-controller="Units" asp-action="Index" asp-route-propertyId="202">Units</a> |
                <a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="502">Unit details</a>
            </td>
        </tr>
        <tr>
            <td>Harbor View 2</td>
            <td>Commercial property</td>
            <td>4</td>
            <td>12</td>
            <td>
                <a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="203">Details</a> |
                <a asp-area="Customer" asp-controller="Units" asp-action="Index" asp-route-propertyId="203">Units</a> |
                <a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="503">Unit details</a>
            </td>
        </tr>
        </tbody>
    </table>
</section>


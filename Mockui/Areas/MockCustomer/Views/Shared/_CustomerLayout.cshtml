@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Customer Mock</title>
    <link rel="stylesheet" href="~/mockui/css/mock-ui.css" asp-append-version="true" />
</head>
<body class="mock-body">
<div class="mock-shell">
    <header class="mock-header">
        <div>
            <p class="mock-eyebrow">Customer Area</p>
            <strong>Portfolio Tracking Workspace</strong>
        </div>
        <nav class="mock-role-switch" aria-label="Role switch navigation">
            <a asp-area="Management" asp-controller="Dashboard" asp-action="Index">Management</a>
            <a asp-area="Customer" asp-controller="Dashboard" asp-action="Index">Customer</a>
            <a asp-area="Resident" asp-controller="Dashboard" asp-action="Index">Resident</a>
        </nav>
    </header>

    <div class="mock-body-grid">
        <aside class="mock-sidebar">
            <div class="mock-company-name">Nordic Housing Group</div>
            <nav>
                <a class="mock-sidebar-link @(currentController == "Dashboard" ? "active" : "")" asp-area="Customer" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="mock-sidebar-link @(currentController == "Tickets" ? "active" : "")" asp-area="Customer" asp-controller="Tickets" asp-action="Index">Tickets</a>
                <a class="mock-sidebar-link @(currentController == "Properties" ? "active" : "")" asp-area="Customer" asp-controller="Properties" asp-action="Index">Properties</a>
                <a class="mock-sidebar-link @(currentController == "Units" ? "active" : "")" asp-area="Customer" asp-controller="Units" asp-action="Index">Units</a>
                <a class="mock-sidebar-link @(currentController == "Updates" ? "active" : "")" asp-area="Customer" asp-controller="Updates" asp-action="Index">Updates</a>
                <a class="mock-sidebar-link @(currentController == "Profile" ? "active" : "")" asp-area="Customer" asp-controller="Profile" asp-action="Index">Profile</a>
            </nav>
        </aside>

        <main class="mock-main">
            <h1 class="mock-page-title">@ViewData["Title"]</h1>
            @RenderBody()
        </main>
    </div>
</div>
</body>
</html>


@model WebApp.ViewModels.Onboarding.FlowChooserViewModel
@{
    ViewData["Title"] = "Onboarding";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-10">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4 p-md-5">
                <h1 class="display-6 fw-semibold mb-3">Choose how you want to continue</h1>
                <p class="text-muted mb-3">Set up your access to enter the platform.</p>

                @if (!string.IsNullOrWhiteSpace(Model?.InfoMessage))
                {
                    <div class="alert alert-info mb-3">@Model.InfoMessage</div>
                }

                @if (!isAuthenticated)
                {
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-controller="Onboarding" asp-action="Register" class="btn btn-primary">Register</a>
                        <a asp-controller="Onboarding" asp-action="Login" class="btn btn-outline-primary">Login</a>
                    </div>
                }
            </div>
        </div>
        
        @if (isAuthenticated) {

            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <div class="card h-100 border-primary">
                        <div class="card-body d-flex flex-column">
                            <h2 class="h5">New management company</h2>
                            <p class="text-muted flex-grow-1">Register your company.</p>
                            <a asp-controller="Onboarding" asp-action="NewManagementCompany" class="btn btn-primary">Start setup</a>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h2 class="h5">Management company employee</h2>
                            <p class="text-muted flex-grow-1">Join an existing management company account.</p>
                            <a asp-controller="Onboarding" asp-action="JoinManagementCompany" class="btn btn-outline-secondary">Open</a>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h2 class="h5">Resident</h2>
                            <p class="text-muted flex-grow-1">Request access to your resident dashboard.</p>
                            <a asp-controller="Onboarding" asp-action="ResidentAccess" class="btn btn-outline-secondary">Open</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>


@{
    ViewData["Title"] = App.Resources.Views.UiText.AccessDenied;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5">
                    <p class="text-uppercase text-muted small mb-2">@App.Resources.Views.UiText.Authorization</p>
                    <h1 class="h2 mb-3">@App.Resources.Views.UiText.AccessDenied</h1>
                    <p class="text-muted mb-4">
                        @App.Resources.Views.UiText.AccessDeniedDescription
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary" asp-controller="Onboarding" asp-action="Index">@App.Resources.Views.UiText.GoToContextChooser</a>
                        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">@App.Resources.Views.UiText.GoToHome</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

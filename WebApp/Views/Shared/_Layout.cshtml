@using App.Domain.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> _signInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Fixvia</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Fixvia</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                     <li class="nav-item">
                         <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">@App.Resources.Views.UiText.Privacy</a>
                     </li>

                     @if (_signInManager.IsSignedIn(User) && User.IsInRole("SystemAdmin") &&
                          (string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), "Home", StringComparison.OrdinalIgnoreCase) ||
                           string.Equals(ViewContext.RouteData.Values["area"]?.ToString(), "Admin", StringComparison.OrdinalIgnoreCase)))
                     {
                         <li class="nav-item dropdown">
                             <a class="nav-link dropdown-toggle text-dark" href="#" id="adminAreaDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                 @App.Resources.Views.Home.Admin
                             </a>
                             <ul class="dropdown-menu" aria-labelledby="adminAreaDropdown">
                                 <li><h6 class="dropdown-header">Company</h6></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="ManagementCompany" asp-action="Index">Management Companies</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="ManagementCompanyRole" asp-action="Index">Management Roles</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="ManagementCompanyUser" asp-action="Index">Management Users</a></li>
                                 <li><hr class="dropdown-divider" /></li>
                                 <li><h6 class="dropdown-header">Property</h6></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="Property" asp-action="Index">Properties</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="PropertyType" asp-action="Index">Property Types</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="Unit" asp-action="Index">Units</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="Lease" asp-action="Index">Leases</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="LeaseRole" asp-action="Index">Lease Roles</a></li>
                                 <li><hr class="dropdown-divider" /></li>
                                 <li><h6 class="dropdown-header">People</h6></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="Customer" asp-action="Index">Customers</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="CustomerRepresentative" asp-action="Index">Customer Representatives</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="CustomerRepresentativeRole" asp-action="Index">Customer Roles</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="Resident" asp-action="Index">Residents</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="ResidentUser" asp-action="Index">Resident Users</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="ResidentContact" asp-action="Index">Resident Contacts</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="Vendor" asp-action="Index">Vendors</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="VendorContact" asp-action="Index">Vendor Contacts</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="Contact" asp-action="Index">Contacts</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="ContactType" asp-action="Index">@App.Resources.Domain.ContactType.contactType</a></li>
                                 <li><hr class="dropdown-divider" /></li>
                                 <li><h6 class="dropdown-header">Tickets</h6></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="Ticket" asp-action="Index">Tickets</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="TicketCategory" asp-action="Index">Ticket Categories</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="TicketStatus" asp-action="Index">Ticket Statuses</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="TicketPriority" asp-action="Index">Ticket Priorities</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="VendorTicketCategory" asp-action="Index">Vendor Ticket Categories</a></li>
                                 <li><hr class="dropdown-divider" /></li>
                                 <li><h6 class="dropdown-header">Work</h6></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="ScheduledWork" asp-action="Index">Scheduled Work</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="WorkStatus" asp-action="Index">Work Statuses</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="WorkLog" asp-action="Index">Work Logs</a></li>
                                 <li><hr class="dropdown-divider" /></li>
                                 <li><h6 class="dropdown-header">Identity</h6></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="AppUser" asp-action="Index">App Users</a></li>
                                 <li><a class="dropdown-item" asp-area="Admin" asp-controller="AppRole" asp-action="Index">App Roles</a></li>
                             </ul>
                         </li>
                     }
                     
                     <partial name="_LanguageSelection"/>
                 </ul>
                <partial name="_LoginPartial"/>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - Fixvia - <a asp-area="" asp-controller="Home" asp-action="Privacy">@App.Resources.Views.UiText.Privacy</a> 
        | @Thread.CurrentThread.CurrentUICulture.Name
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

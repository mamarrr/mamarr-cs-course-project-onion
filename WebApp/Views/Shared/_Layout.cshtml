@using App.Domain.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> _signInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - WebApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">WebApp</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                     <li class="nav-item">
                         <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                     </li>

                     <li class="nav-item dropdown">
                         <a class="nav-link dropdown-toggle text-dark" href="#" id="mockUiDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                             Mock UI
                         </a>
                         <ul class="dropdown-menu" aria-labelledby="mockUiDropdown">
                             <li><a class="dropdown-item" asp-area="" asp-controller="MockUi" asp-action="Index">Mock UI Landing</a></li>
                             <li><hr class="dropdown-divider" /></li>
                             <li><h6 class="dropdown-header">Management</h6></li>
                             <li><a class="dropdown-item" asp-area="Management" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                             <li><a class="dropdown-item" asp-area="Management" asp-controller="Tickets" asp-action="Index">Tickets</a></li>
                             <li><a class="dropdown-item" asp-area="Management" asp-controller="Properties" asp-action="Index">Properties</a></li>
                             <li><a class="dropdown-item" asp-area="Management" asp-controller="Customers" asp-action="Index">Customers</a></li>
                             <li><a class="dropdown-item" asp-area="Management" asp-controller="Vendors" asp-action="Index">Vendors</a></li>
                             <li><hr class="dropdown-divider" /></li>
                             <li><h6 class="dropdown-header">Customer</h6></li>
                             <li><a class="dropdown-item" asp-area="Customer" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                             <li><a class="dropdown-item" asp-area="Customer" asp-controller="Tickets" asp-action="Index">Tickets</a></li>
                             <li><a class="dropdown-item" asp-area="Customer" asp-controller="Properties" asp-action="Index">Properties</a></li>
                             <li><a class="dropdown-item" asp-area="Customer" asp-controller="Updates" asp-action="Index">Updates</a></li>
                             <li><a class="dropdown-item" asp-area="Customer" asp-controller="Profile" asp-action="Index">Profile</a></li>
                             <li><hr class="dropdown-divider" /></li>
                             <li><h6 class="dropdown-header">Resident</h6></li>
                             <li><a class="dropdown-item" asp-area="Resident" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                             <li><a class="dropdown-item" asp-area="Resident" asp-controller="Tickets" asp-action="MyTickets">My Tickets</a></li>
                             <li><a class="dropdown-item" asp-area="Resident" asp-controller="Tickets" asp-action="NewTicket">New Ticket</a></li>
                             <li><a class="dropdown-item" asp-area="Resident" asp-controller="Support" asp-action="Index">Support</a></li>
                             <li><a class="dropdown-item" asp-area="Resident" asp-controller="Profile" asp-action="Index">Profile</a></li>
                         </ul>
                     </li>
                     
                     <partial name="_LanguageSelection"/>
                 </ul>
                <partial name="_LoginPartial"/>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - WebApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a> 
        | @Thread.CurrentThread.CurrentUICulture.Name
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

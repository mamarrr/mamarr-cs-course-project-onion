@model WebApp.ViewModels.Resident.DashboardPageViewModel
@{
    var currentSectionLabel = (ViewData["CurrentSectionLabel"] as string) ?? App.Resources.Views.UiText.Dashboard;
}

<section class="management-card mb-4">
    <p class="management-eyebrow mb-2">@T("ResidentDashboard", "Resident dashboard")</p>
    <h2 class="mb-1">@Model.ResidentDisplayName</h2>
    <p class="management-muted mb-0">@string.Format(T("ResidentDashboardIntro", "Resident workspace for {0} in {1}."), Model.ResidentDisplayName, Model.CompanyName)</p>
    @if (!string.IsNullOrWhiteSpace(Model.ResidentSupportingText))
    {
        <p class="management-muted mb-0">@Model.ResidentSupportingText</p>
    }
</section>

<section class="management-card">
    <h3>@currentSectionLabel</h3>
    <p class="management-muted mb-0">@string.Format(T("ResidentSectionPlaceholder", "{0} content is planned and will be added in a later increment."), currentSectionLabel)</p>
</section>

@functions {
    private static string T(string key, string fallback)
    {
        return App.Resources.Views.UiText.ResourceManager.GetString(key) ?? fallback;
    }
}

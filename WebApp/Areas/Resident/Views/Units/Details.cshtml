@{
    var unitId = (int?)ViewData["UnitId"] ?? 301;
    ViewData["Title"] = $"Unit Details #{unitId}";
}

<div class="mock-alert info">Unit details are scoped to one specific unit and do not mix data from other resident-linked units.</div>

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Unit summary</h2>
        <ul class="mock-link-list">
            <li>Unit: 18</li>
            <li>Floor: 5</li>
            <li>Area: 62 m²</li>
            <li>Lease role: Tenant</li>
        </ul>
    </section>
    <section class="mock-card">
        <h2>Parent property context</h2>
        <ul class="mock-link-list">
            <li>Property: <a asp-area="Resident" asp-controller="Properties" asp-action="Details" asp-route-id="201">Riverside 12</a></li>
            <li>Address: Riverside St 12, Tallinn</li>
            <li>Building type: Apartment building</li>
        </ul>
    </section>
</div>

<section class="mock-card">
    <h2>Tickets for this unit</h2>
    <table class="mock-table">
        <thead>
        <tr>
            <th>Ticket</th>
            <th>Status</th>
            <th>Updated</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>#RT-701 Bathroom faucet drip</td>
            <td><span class="mock-badge">Scheduled</span></td>
            <td>Today</td>
            <td><a asp-area="Resident" asp-controller="Tickets" asp-action="Details" asp-route-id="701">Ticket details</a></td>
        </tr>
        <tr>
            <td>#RT-704 Balcony door seal issue</td>
            <td><span class="mock-badge success">In Progress</span></td>
            <td>Yesterday</td>
            <td><a asp-area="Resident" asp-controller="Tickets" asp-action="Details" asp-route-id="704">Ticket details</a></td>
        </tr>
        </tbody>
    </table>

    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Properties" asp-action="Details" asp-route-id="201">Open parent property</a>
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Units" asp-action="Index">Back to my units</a>
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Tickets" asp-action="NewTicket">Create ticket for this unit (mock)</a>
    </div>
</section>

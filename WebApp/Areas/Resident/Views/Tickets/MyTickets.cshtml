@{
    ViewData["Title"] = "My Tickets";
}

<div class="mock-alert info">Ticket list is aggregated across all units linked to your resident profile.</div>

<section class="mock-card">
    <h2>My tickets</h2>
    <table class="mock-table">
        <thead>
        <tr>
            <th>Ticket</th>
            <th>Unit</th>
            <th>Property</th>
            <th>Status</th>
            <th>Updated</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>#RT-701 Bathroom faucet drip</td>
            <td><a asp-area="Resident" asp-controller="Units" asp-action="Details" asp-route-id="301">Unit 18</a></td>
            <td><a asp-area="Resident" asp-controller="Properties" asp-action="Details" asp-route-id="201">Riverside 12</a></td>
            <td><span class="mock-badge">Scheduled</span></td>
            <td>Today</td>
            <td>
                <a asp-area="Resident" asp-controller="Tickets" asp-action="Details" asp-route-id="701">Details</a>
            </td>
        </tr>
        <tr>
            <td>#RT-702 Bedroom radiator noise</td>
            <td><a asp-area="Resident" asp-controller="Units" asp-action="Details" asp-route-id="303">Unit 21</a></td>
            <td><a asp-area="Resident" asp-controller="Properties" asp-action="Details" asp-route-id="201">Riverside 12</a></td>
            <td><span class="mock-badge success">In Progress</span></td>
            <td>Yesterday</td>
            <td>
                <a asp-area="Resident" asp-controller="Tickets" asp-action="Details" asp-route-id="702">Details</a>
            </td>
        </tr>
        <tr>
            <td>#RT-703 Intercom static sound</td>
            <td><a asp-area="Resident" asp-controller="Units" asp-action="Details" asp-route-id="302">Unit A-02</a></td>
            <td><a asp-area="Resident" asp-controller="Properties" asp-action="Details" asp-route-id="202">Oak Street 5</a></td>
            <td><span class="mock-badge warning">Completed</span></td>
            <td>2 days ago</td>
            <td>
                <a asp-area="Resident" asp-controller="Tickets" asp-action="Details" asp-route-id="703">Details</a>
            </td>
        </tr>
        </tbody>
    </table>

    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Tickets" asp-action="NewTicket">Create new ticket</a>
        <a class="mock-btn ghost" asp-area="Resident" asp-controller="Units" asp-action="Index">Open my units</a>
    </div>
</section>

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Resident Mock</title>
    <link rel="stylesheet" href="~/css/mock-ui.css" asp-append-version="true" />
</head>
<body class="mock-body">
<div class="mock-shell">
    <header class="mock-header">
        <div>
            <p class="mock-eyebrow">Resident Area</p>
            <strong>My Maintenance Workspace</strong>
        </div>
        <nav class="mock-role-switch" aria-label="Role switch navigation">
            <a asp-area="" asp-controller="MockUi" asp-action="Index">Mock UI</a>
            <a asp-area="Management" asp-controller="Dashboard" asp-action="Index">Management</a>
            <a asp-area="Customer" asp-controller="Dashboard" asp-action="Index">Customer</a>
            <a asp-area="Resident" asp-controller="Dashboard" asp-action="Index">Resident</a>
        </nav>
    </header>

    <div class="mock-body-grid">
        <aside class="mock-sidebar">
            <div class="mock-company-name">Resident Workspace (Multi-unit)</div>
            <nav>
                <a class="mock-sidebar-link @(currentController == "Dashboard" ? "active" : "")" asp-area="Resident" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="mock-sidebar-link @(currentController == "Tickets" && (currentAction == "MyTickets" || currentAction == "Details") ? "active" : "")" asp-area="Resident" asp-controller="Tickets" asp-action="MyTickets">My Tickets</a>
                <a class="mock-sidebar-link @(currentController == "Tickets" && currentAction == "NewTicket" ? "active" : "")" asp-area="Resident" asp-controller="Tickets" asp-action="NewTicket">New Ticket</a>
                <a class="mock-sidebar-link @(currentController == "Units" ? "active" : "")" asp-area="Resident" asp-controller="Units" asp-action="Index">My Units</a>
                <a class="mock-sidebar-link @(currentController == "Support" ? "active" : "")" asp-area="Resident" asp-controller="Support" asp-action="Index">Support</a>
                <a class="mock-sidebar-link @(currentController == "Profile" ? "active" : "")" asp-area="Resident" asp-controller="Profile" asp-action="Index">Profile</a>
            </nav>
        </aside>

        <main class="mock-main">
            <h1 class="mock-page-title">@ViewData["Title"]</h1>
            @RenderBody()
        </main>
    </div>
</div>
</body>
</html>

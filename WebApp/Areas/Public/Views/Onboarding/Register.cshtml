@model WebApp.ViewModels.Onboarding.RegisterViewModel
@{
    ViewData["Title"] = App.Resources.Views.UiText.Register;
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">@App.Resources.Views.UiText.CreateAccount</h1>

                <form asp-action="Register" asp-controller="Onboarding" method="post" data-disable-submit>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control" autocomplete="given-name" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control" autocomplete="family-name" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">@App.Resources.Views.UiText.Register</button>
                        <a class="btn btn-link" asp-controller="Onboarding" asp-action="Login">@App.Resources.Views.UiText.AlreadyHaveAccountLogin</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const form = document.querySelector('form[data-disable-submit]');
            if (!form) return;
            form.addEventListener('submit', function () {
                const button = form.querySelector('button[type="submit"]');
                if (!button) return;
                button.disabled = true;
                button.textContent = '@App.Resources.Views.UiText.PleaseWait';
            });
        })();
    </script>
}


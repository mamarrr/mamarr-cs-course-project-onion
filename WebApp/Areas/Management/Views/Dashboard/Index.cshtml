@{
    ViewData["Title"] = "Management Dashboard";
}

<div class="mock-alert info">Operational mock dashboard with direct drill-down links to tickets, properties, units, customers, and vendors.</div>

<div class="mock-grid mock-grid-3">
    <section class="mock-card">
        <h2>Occupancy overview</h2>
        <p class="mock-kpi">93%</p>
        <p class="mock-muted">Current active occupancy across managed properties.</p>
    </section>
    <section class="mock-card">
        <h2>Active maintenance</h2>
        <p class="mock-kpi">42 tickets</p>
        <span class="mock-badge warning">12 high priority</span>
    </section>
    <section class="mock-card">
        <h2>Upcoming scheduled work</h2>
        <p class="mock-muted">8 visits in next 72 hours.</p>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Scheduling" asp-route-id="1002">Open scheduling board</a>
    </section>
</div>

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Top unresolved properties</h2>
        <ul class="mock-link-list">
            <li><a asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="201">Riverside 12</a> — 7 open tickets</li>
            <li><a asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="202">Oak Street 5</a> — 5 open tickets</li>
            <li><a asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="203">Harbor View 2</a> — 4 open tickets</li>
        </ul>
        <div class="mock-actions">
            <a class="mock-btn ghost" asp-area="Management" asp-controller="Properties" asp-action="Index">View all properties</a>
            <a class="mock-btn ghost" asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="501">Open unit details sample</a>
        </div>
    </section>
    <section class="mock-card">
        <h2>Top active vendors</h2>
        <ul class="mock-link-list">
            <li><a asp-area="Management" asp-controller="Vendors" asp-action="Details" asp-route-id="401">Northfix OÜ</a> — 14 assigned jobs</li>
            <li><a asp-area="Management" asp-controller="Vendors" asp-action="Details" asp-route-id="402">PipePro AS</a> — 11 assigned jobs</li>
            <li><a asp-area="Management" asp-controller="Vendors" asp-action="Details" asp-route-id="403">Elektriabi OÜ</a> — 9 assigned jobs</li>
        </ul>
        <div class="mock-actions">
            <a class="mock-btn ghost" asp-area="Management" asp-controller="Customers" asp-action="Index">Customer accounts</a>
            <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1001">Open latest ticket</a>
        </div>
    </section>
</div>

@using System.Threading
@using WebApp.Services.ManagementLayout
@inject IManagementLayoutViewModelProvider LayoutModelProvider

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var companySlug = ViewContext.RouteData.Values["companySlug"]?.ToString() ?? string.Empty;
    var currentPathAndQuery = $"{Context.Request.Path}{Context.Request.QueryString}";
    var currentUiCultureName = Thread.CurrentThread.CurrentUICulture.Name;
    var layoutVm = await LayoutModelProvider.BuildAsync(
        User,
        currentController,
        companySlug,
        currentPathAndQuery,
        currentUiCultureName,
        Context.RequestAborted);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/management-ui.css" asp-append-version="true" />
</head>
<body class="management-body">
<div class="management-shell">
    <header class="management-header">
        <div>
            <p class="management-eyebrow">Management Area</p>
            <strong>@layoutVm.ManagementCompanyName</strong>
        </div>
        <div class="management-header-actions">
            <div class="dropdown">
                <button class="management-btn ghost dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    Context
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">Companies</h6></li>
                    @if (layoutVm.ManagementContexts.Count == 0)
                    {
                        <li><span class="dropdown-item-text text-muted">No company contexts</span></li>
                    }
                    else
                    {
                        foreach (var companyContext in layoutVm.ManagementContexts)
                        {
                            <li>
                                <a class="dropdown-item" asp-area="" asp-controller="Onboarding" asp-action="SetContext" asp-route-type="management" asp-route-id="@companyContext.Id" asp-route-returnUrl="@layoutVm.CurrentPathAndQuery">@companyContext.Name</a>
                            </li>
                        }
                    }

                    <li><hr class="dropdown-divider" /></li>
                    <li><h6 class="dropdown-header">Customers</h6></li>
                    @if (layoutVm.CustomerContexts.Count == 0)
                    {
                        <li><span class="dropdown-item-text text-muted">No customer contexts</span></li>
                    }
                    else
                    {
                        foreach (var customerContext in layoutVm.CustomerContexts)
                        {
                            <li>
                                <a class="dropdown-item" asp-area="" asp-controller="Onboarding" asp-action="SetContext" asp-route-type="customer" asp-route-id="@customerContext.Id" asp-route-returnUrl="@layoutVm.CurrentPathAndQuery">@customerContext.Name</a>
                            </li>
                        }
                    }

                    <li><hr class="dropdown-divider" /></li>
                    <li><h6 class="dropdown-header">Resident</h6></li>
                    @if (layoutVm.HasResidentContext)
                    {
                        <li>
                            <a class="dropdown-item" asp-area="" asp-controller="Onboarding" asp-action="SetContext" asp-route-type="resident" asp-route-returnUrl="@layoutVm.CurrentPathAndQuery">Resident Dashboard</a>
                        </li>
                    }
                    else
                    {
                        <li><span class="dropdown-item-text text-muted">No resident context</span></li>
                    }
                </ul>
            </div>

            <form method="post" asp-area="" asp-controller="Onboarding" asp-action="Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="management-btn ghost">Logout</button>
            </form>
        </div>
    </header>

    <div class="management-body-grid">
        <aside class="management-sidebar">
            <div class="management-company-name">@layoutVm.ManagementCompanyName</div>
            <nav>
                <a class="management-sidebar-link @(layoutVm.CurrentController == "Dashboard" ? "active" : "")" asp-route="management_dashboard" asp-route-companySlug="@layoutVm.CompanySlug">Dashboard</a>
                <span class="management-sidebar-link disabled">Tickets</span>
                <span class="management-sidebar-link disabled">Properties</span>
                <span class="management-sidebar-link disabled">Customers</span>
                @if (layoutVm.CanManageCompanyUsers)
                {
                    <a class="management-sidebar-link @(layoutVm.CurrentController == "Users" ? "active" : "")" asp-area="Management" asp-controller="Users" asp-action="Index" asp-route-companySlug="@layoutVm.CompanySlug">Users</a>
                }
                <span class="management-sidebar-link disabled">Vendors</span>
            </nav>

            <div class="management-sidebar-footer">
                <a class="management-btn management-sidebar-cta" asp-area="" asp-controller="Onboarding" asp-action="Index" asp-route-showChooser="true">New context</a>
                <div class="management-language-title">Language (@layoutVm.CurrentUiCultureName)</div>
                <div class="management-language-list">
                    @foreach (var item in layoutVm.CultureOptions)
                    {
                        <a class="management-language-link @(item.IsCurrent ? "active" : "")"
                           asp-area=""
                           asp-controller="Home"
                           asp-action="SetLanguage"
                           asp-route-culture="@item.Value"
                           asp-route-returnUrl="@layoutVm.CurrentPathAndQuery">
                            @item.Text
                        </a>
                    }
                </div>
                <a class="management-sidebar-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </aside>

        <main class="management-main">
            <h1 class="management-page-title">@ViewData["Title"]</h1>
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

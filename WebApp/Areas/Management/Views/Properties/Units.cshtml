@{
    var propertyId = (int?)ViewData["PropertyId"] ?? 201;
    ViewData["Title"] = $"Property Units #{propertyId}";
}

<section class="mock-card">
    <h2>Units in Riverside 12</h2>
    <table class="mock-table">
        <thead>
        <tr>
            <th>Unit</th>
            <th>Occupancy</th>
            <th>Open tickets</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>Unit 5B</td>
            <td>Occupied</td>
            <td>2</td>
            <td>
                <a asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="501">Unit details</a> |
                <a asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1001">Related ticket</a>
            </td>
        </tr>
        <tr>
            <td>Unit 6A</td>
            <td>Occupied</td>
            <td>1</td>
            <td>
                <a asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="504">Unit details</a> |
                <a asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1004">Related ticket</a>
            </td>
        </tr>
        <tr>
            <td>Unit 7C</td>
            <td>Vacant</td>
            <td>0</td>
            <td>
                <a asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="505">Unit details</a>
            </td>
        </tr>
        </tbody>
    </table>
    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="@propertyId">Back to property details</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Properties" asp-action="Index">Back to properties list</a>
    </div>
</section>

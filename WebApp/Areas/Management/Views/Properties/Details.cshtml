@{
    var propertyId = (int?)ViewData["PropertyId"] ?? 201;
    ViewData["Title"] = $"Property Details #{propertyId}";
}

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Property profile</h2>
        <ul class="mock-link-list">
            <li>Name: Riverside 12</li>
            <li>Type: Apartment building</li>
            <li>Managed units: 34</li>
            <li>Open tickets: 7</li>
        </ul>
    </section>
    <section class="mock-card">
        <h2>Operational signals</h2>
        <p><span class="mock-badge warning">2 urgent tickets</span></p>
        <p><span class="mock-badge">Next scheduled work: Tomorrow 13:30</span></p>
        <p class="mock-muted">Use this page as the property-specific decision point before opening individual units.</p>
    </section>
</div>

<section class="mock-card">
    <h2>Quick links</h2>
    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Properties" asp-action="Units" asp-route-id="@propertyId">Open property units list</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="501">Open Unit 5B details</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1001">Related ticket details</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Properties" asp-action="Index">Back to properties</a>
    </div>
</section>

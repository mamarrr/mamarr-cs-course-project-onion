@{
    var ticketId = (int?)ViewData["TicketId"] ?? 1001;
    ViewData["Title"] = $"Ticket Details #{ticketId}";
}

<div class="mock-alert info">Ticket lifecycle context from triage through closure preparation.</div>

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Ticket summary</h2>
        <ul class="mock-link-list">
            <li>Category: Plumbing</li>
            <li>Status: <span class="mock-badge">Assigned</span></li>
            <li>Priority: <span class="mock-badge warning">High</span></li>
            <li>Created: 2026-03-27 09:12</li>
        </ul>
    </section>
    <section class="mock-card">
        <h2>Linked context</h2>
        <ul class="mock-link-list">
            <li>Property: <a asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="201">Riverside 12</a></li>
            <li>Unit: <a asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="501">Unit 5B</a></li>
            <li>Customer: <a asp-area="Management" asp-controller="Customers" asp-action="Details" asp-route-id="301">Nordic Housing Group</a></li>
            <li>Vendor: <a asp-area="Management" asp-controller="Vendors" asp-action="Details" asp-route-id="401">Northfix OÜ</a></li>
        </ul>
    </section>
</div>

<section class="mock-card">
    <h2>Issue description</h2>
    <p class="mock-muted">Resident reported recurring kitchen sink leak. Initial triage completed and vendor assigned for on-site diagnostics.</p>
    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Activity" asp-route-id="@ticketId">View activity/work log</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Scheduling" asp-route-id="@ticketId">Open assignment &amp; scheduling</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Index">Back to tickets list</a>
    </div>
</section>

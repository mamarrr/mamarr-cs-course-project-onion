@{
    var ticketId = (int?)ViewData["TicketId"] ?? 1001;
    ViewData["Title"] = $"Ticket Activity #{ticketId}";
}

<section class="mock-card">
    <h2>Work log and activity timeline</h2>
    <ol class="mock-timeline">
        <li><strong>09:12</strong> — Ticket created by resident (Unit 5B).</li>
        <li><strong>09:28</strong> — Support specialist validated category and priority.</li>
        <li><strong>09:44</strong> — Vendor Northfix OÜ assigned.</li>
        <li><strong>10:05</strong> — Awaiting visit slot confirmation.</li>
    </ol>
    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="@ticketId">Ticket details</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Scheduling" asp-route-id="@ticketId">Assignment &amp; scheduling</a>
        <a class="mock-btn ghost" asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="501">Related unit details</a>
    </div>
</section>

@{
    ViewData["Title"] = "Management Tickets";
}

<div class="mock-alert info">Static ticket board placeholder for assignment, scheduling, and lifecycle updates.</div>

<div class="mock-card">
    <h2>Recently added tickets</h2>
    <table class="mock-table">
        <thead>
        <tr>
            <th>Ticket</th>
            <th>Property</th>
            <th>Unit</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td><a asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1001">#MT-1001 Kitchen sink leak</a></td>
            <td><a asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="201">Riverside 12</a></td>
            <td><a asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="501">Unit 5B</a></td>
            <td><span class="mock-badge">Assigned</span></td>
            <td><span class="mock-badge warning">High</span></td>
            <td>
                <a asp-area="Management" asp-controller="Tickets" asp-action="Activity" asp-route-id="1001">Activity</a> |
                <a asp-area="Management" asp-controller="Tickets" asp-action="Scheduling" asp-route-id="1001">Scheduling</a>
            </td>
        </tr>
        <tr>
            <td><a asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1002">#MT-1002 Elevator check</a></td>
            <td><a asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="202">Oak Street 5</a></td>
            <td><a asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="502">Unit 1A</a></td>
            <td><span class="mock-badge">Scheduled</span></td>
            <td><span class="mock-badge">Medium</span></td>
            <td>
                <a asp-area="Management" asp-controller="Tickets" asp-action="Activity" asp-route-id="1002">Activity</a> |
                <a asp-area="Management" asp-controller="Tickets" asp-action="Scheduling" asp-route-id="1002">Scheduling</a>
            </td>
        </tr>
        <tr>
            <td><a asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1003">#MT-1003 Hallway lights</a></td>
            <td><a asp-area="Management" asp-controller="Properties" asp-action="Details" asp-route-id="203">Harbor View 2</a></td>
            <td><a asp-area="Management" asp-controller="Units" asp-action="Details" asp-route-id="503">Unit C-12</a></td>
            <td><span class="mock-badge success">In Progress</span></td>
            <td><span class="mock-badge">Low</span></td>
            <td>
                <a asp-area="Management" asp-controller="Tickets" asp-action="Activity" asp-route-id="1003">Activity</a> |
                <a asp-area="Management" asp-controller="Tickets" asp-action="Scheduling" asp-route-id="1003">Scheduling</a>
            </td>
        </tr>
        </tbody>
    </table>
</div>

<div class="mock-actions">
    <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Details" asp-route-id="1001">Open ticket details</a>
    <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Activity" asp-route-id="1001">Open work log/activity</a>
    <a class="mock-btn ghost" asp-area="Management" asp-controller="Tickets" asp-action="Scheduling" asp-route-id="1001">Open assignment/scheduling</a>
</div>

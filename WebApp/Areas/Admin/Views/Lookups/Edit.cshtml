@model WebApp.ViewModels.Admin.Lookups.AdminLookupEditViewModel

<section class="admin-card">
    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Type" />
        <div class="mb-3">
            <label asp-for="Code" class="form-label"></label>
            <input asp-for="Code" class="form-control" readonly="@Model.IsProtected" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Label" class="form-label"></label>
            <input asp-for="Label" class="form-control" />
            <span asp-validation-for="Label" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">@App.Resources.Views.AdminText.Save</button>
        <a class="btn btn-outline-secondary" asp-action="List" asp-route-lookupType="@Model.Type">@App.Resources.Views.AdminText.Cancel</a>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

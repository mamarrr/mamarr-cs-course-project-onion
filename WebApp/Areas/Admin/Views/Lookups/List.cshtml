@model WebApp.ViewModels.Admin.Lookups.AdminLookupListViewModel

<div class="admin-toolbar">
    <div class="btn-group flex-wrap">
        @foreach (var type in Model.LookupTypes)
        {
            <a class="btn @(type.Type == Model.Type ? "btn-primary" : "btn-outline-primary")" asp-action="List" asp-route-lookupType="@type.Type">@type.Title</a>
        }
    </div>
    <a class="btn btn-success" asp-action="Create" asp-route-lookupType="@Model.Type">@App.Resources.Views.AdminText.Create</a>
</div>

@if (Model.Items.Count == 0)
{
    <partial name="_AdminEmptyState" model="@App.Resources.Views.AdminText.NoLookupItemsConfigured" />
}
else
{
    <div class="admin-table table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>@App.Resources.Views.AdminText.Code</th><th>@App.Resources.Views.AdminText.Label</th><th>@App.Resources.Views.AdminText.Protected</th><th>@App.Resources.Views.AdminText.Actions</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><code>@item.Code</code></td>
                    <td>@item.Label</td>
                    <td>@(item.IsProtected ? App.Resources.Views.AdminText.Yes : App.Resources.Views.AdminText.No)</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-lookupType="@Model.Type" asp-route-id="@item.Id">@App.Resources.Views.AdminText.Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-lookupType="@Model.Type" asp-route-id="@item.Id">@App.Resources.Views.AdminText.Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

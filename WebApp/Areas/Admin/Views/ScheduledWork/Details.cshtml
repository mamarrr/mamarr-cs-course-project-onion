@model App.Domain.ScheduledWork

@{
    ViewData["Title"] = "Details";
}

<h1>@App.Resources.Views.AdminScaffoldText.Details</h1>

<div>
    <h4>ScheduledWork</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ScheduledStart)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ScheduledStart)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ScheduledEnd)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ScheduledEnd)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RealStart)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RealStart)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RealEnd)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RealEnd)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Notes)
        </dt>
        <dd class = "col-sm-10">
            @(Model.Notes?.ToString())
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedAt)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Vendor)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Vendor!.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Ticket)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Ticket!.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.WorkStatus)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.WorkStatus!.Code)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">@App.Resources.Views.AdminScaffoldText.Edit</a> |
    <a asp-action="Index">@App.Resources.Views.AdminScaffoldText.BackToList</a>
</div>

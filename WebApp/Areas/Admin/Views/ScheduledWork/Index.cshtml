@model IEnumerable<App.Domain.ScheduledWork>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ScheduledStart)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ScheduledEnd)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RealStart)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RealEnd)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Notes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vendor)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Ticket)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.WorkStatus)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ScheduledStart)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ScheduledEnd)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RealStart)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RealEnd)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Notes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Vendor!.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Ticket!.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.WorkStatus!.Code)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

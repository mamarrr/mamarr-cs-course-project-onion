            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RegistryCode)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RegistryCode)

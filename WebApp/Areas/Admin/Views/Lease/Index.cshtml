@model IEnumerable<App.Domain.Lease>

@{
    ViewData["Title"] = "Index";
}

<h1>@App.Resources.Views.AdminScaffoldText.Index</h1>

<p>
    <a asp-action="Create">@App.Resources.Views.AdminScaffoldText.CreateNew</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsActive)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Notes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LeaseRole)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Unit)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Resident)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.StartDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsActive)
            </td>
            <td>
                @(item.Notes?.ToString())
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LeaseRole!.Code)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Unit!.UnitNr)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Resident!.FirstName)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">@App.Resources.Views.AdminScaffoldText.Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">@App.Resources.Views.AdminScaffoldText.Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">@App.Resources.Views.AdminScaffoldText.Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

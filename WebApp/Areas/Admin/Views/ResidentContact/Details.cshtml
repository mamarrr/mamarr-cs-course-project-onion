@model App.Domain.ResidentContact

@{
    ViewData["Title"] = "Details";
}

<h1>@App.Resources.Views.AdminScaffoldText.Details</h1>

<div>
    <h4>ResidentContact</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ValidFrom)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ValidFrom)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ValidTo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ValidTo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Confirmed)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Confirmed)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsPrimary)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsPrimary)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Resident)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Resident!.FirstName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Contact)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Contact!.ContactValue)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">@App.Resources.Views.AdminScaffoldText.Edit</a> |
    <a asp-action="Index">@App.Resources.Views.AdminScaffoldText.BackToList</a>
</div>

@model WebApp.ViewModels.ContactType.ContactTypeDetailsViewModel

@{
    ViewData["Title"] = "Details";
}

<h1>@App.Resources.Views.AdminScaffoldText.Details</h1>

<div>
    <h4>ContactType</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @App.Resources.Domain.ContactType.Code
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Code)
        </dd>
        <dt class = "col-sm-2">
            @App.Resources.Domain.ContactType.Label
        </dt>
        <dd class = "col-sm-10">
            @Model.Label.ToString()
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">@App.Resources.Views.AdminScaffoldText.Edit</a> |
    <a asp-action="Index">@App.Resources.Views.AdminScaffoldText.BackToList</a>
</div>

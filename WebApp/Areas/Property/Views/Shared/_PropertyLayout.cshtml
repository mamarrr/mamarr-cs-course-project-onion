@using System.Threading
@using WebApp.Services.SharedLayout
@using WebApp.ViewModels.Management.CustomerProperties
@inject IWorkspaceLayoutContextProvider LayoutModelProvider
@{
    var propertyLayoutVm = ViewData["PropertyLayout"] as PropertyLayoutViewModel;
    if (propertyLayoutVm == null)
    {
        throw new InvalidOperationException("Property layout context is missing.");
    }

    var currentPathAndQuery = $"{Context.Request.Path}{Context.Request.QueryString}";
    var currentUiCultureName = Thread.CurrentThread.CurrentUICulture.Name;
    var sharedLayoutVm = await LayoutModelProvider.BuildAsync(
        User,
        ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty,
        propertyLayoutVm.CompanySlug,
        currentPathAndQuery,
        currentUiCultureName,
        Context.RequestAborted);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @T("Property", "Property")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/management-ui.css" asp-append-version="true" />
</head>
<body class="management-body">
<div class="management-shell">
    <header class="management-header">
        <div>
            <p class="management-eyebrow mb-1">@T("PropertyWorkspace", "Property workspace")</p>
            <strong>
                <a class="text-decoration-none" asp-route="management_dashboard" asp-route-companySlug="@propertyLayoutVm.CompanySlug">
                    @propertyLayoutVm.CompanyName
                </a>
            </strong>
            <div class="text-muted">
                <a class="text-decoration-none"
                   asp-area="Customer"
                   asp-controller="CustomerDashboard"
                   asp-action="Index"
                   asp-route-companySlug="@propertyLayoutVm.CompanySlug"
                   asp-route-customerSlug="@propertyLayoutVm.CustomerSlug">
                    @propertyLayoutVm.CustomerName
                </a>
            </div>
            <div class="text-muted">
                <a class="text-decoration-none"
                   asp-area="Property"
                   asp-controller="PropertyDashboard"
                   asp-action="Index"
                   asp-route-companySlug="@propertyLayoutVm.CompanySlug"
                   asp-route-customerSlug="@propertyLayoutVm.CustomerSlug"
                   asp-route-propertySlug="@propertyLayoutVm.PropertySlug">
                    @propertyLayoutVm.PropertyName
                </a>
            </div>
        </div>
        <div class="management-header-actions">
            <div class="dropdown">
                <button class="management-btn ghost dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    @App.Resources.Views.UiText.Context
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">@App.Resources.Views.UiText.Companies</h6></li>
                    @if (sharedLayoutVm.ManagementContexts.Count == 0)
                    {
                        <li><span class="dropdown-item-text text-muted">@App.Resources.Views.UiText.NoCompanyContexts</span></li>
                    }
                    else
                    {
                        foreach (var companyContext in sharedLayoutVm.ManagementContexts)
                        {
                            <li>
                                <a class="dropdown-item" asp-area="" asp-controller="Onboarding" asp-action="SetContext" asp-route-type="management" asp-route-id="@companyContext.Id" asp-route-returnUrl="@sharedLayoutVm.CurrentPathAndQuery">@companyContext.Name</a>
                            </li>
                        }
                    }

                    <li><hr class="dropdown-divider" /></li>
                    <li><h6 class="dropdown-header">@App.Resources.Views.UiText.Customers</h6></li>
                    @if (sharedLayoutVm.CustomerContexts.Count == 0)
                    {
                        <li><span class="dropdown-item-text text-muted">@App.Resources.Views.UiText.NoCustomerContexts</span></li>
                    }
                    else
                    {
                        foreach (var customerContext in sharedLayoutVm.CustomerContexts)
                        {
                            <li>
                                <a class="dropdown-item" asp-area="" asp-controller="Onboarding" asp-action="SetContext" asp-route-type="customer" asp-route-id="@customerContext.Id" asp-route-returnUrl="@sharedLayoutVm.CurrentPathAndQuery">@customerContext.Name</a>
                            </li>
                        }
                    }

                    <li><hr class="dropdown-divider" /></li>
                    <li><h6 class="dropdown-header">@App.Resources.Views.UiText.Resident</h6></li>
                    @if (sharedLayoutVm.HasResidentContext)
                    {
                        <li>
                            <a class="dropdown-item" asp-area="" asp-controller="Onboarding" asp-action="SetContext" asp-route-type="resident" asp-route-returnUrl="@sharedLayoutVm.CurrentPathAndQuery">@App.Resources.Views.UiText.ResidentDashboard</a>
                        </li>
                    }
                    else
                    {
                        <li><span class="dropdown-item-text text-muted">@App.Resources.Views.UiText.NoResidentContext</span></li>
                    }
                </ul>
            </div>

            <form method="post" asp-area="" asp-controller="Onboarding" asp-action="Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="management-btn ghost">@App.Resources.Views.UiText.Logout</button>
            </form>
        </div>
    </header>

    <div class="management-body-grid">
        <aside class="management-sidebar">
            <div class="management-company-name">@propertyLayoutVm.PropertyName</div>
            <nav>
                <a class="management-sidebar-link @(propertyLayoutVm.CurrentSection == "Dashboard" ? "active" : "")"
                   asp-area="Property"
                   asp-controller="PropertyDashboard"
                   asp-action="Index"
                   asp-route-companySlug="@propertyLayoutVm.CompanySlug"
                   asp-route-customerSlug="@propertyLayoutVm.CustomerSlug"
                   asp-route-propertySlug="@propertyLayoutVm.PropertySlug">@App.Resources.Views.UiText.Dashboard</a>

                <a class="management-sidebar-link @(propertyLayoutVm.CurrentSection == "Profile" ? "active" : "")"
                   asp-area="Property"
                   asp-controller="PropertyDashboard"
                   asp-action="Profile"
                   asp-route-companySlug="@propertyLayoutVm.CompanySlug"
                   asp-route-customerSlug="@propertyLayoutVm.CustomerSlug"
                   asp-route-propertySlug="@propertyLayoutVm.PropertySlug">@T("Profile", "Profile")</a>

                <a class="management-sidebar-link @(propertyLayoutVm.CurrentSection == "Units" ? "active" : "")"
                   asp-area="Property"
                   asp-controller="PropertyUnits"
                   asp-action="Units"
                   asp-route-companySlug="@propertyLayoutVm.CompanySlug"
                   asp-route-customerSlug="@propertyLayoutVm.CustomerSlug"
                   asp-route-propertySlug="@propertyLayoutVm.PropertySlug">@T("Units", "Units")</a>

                <a class="management-sidebar-link @(propertyLayoutVm.CurrentSection == "Residents" ? "active" : "")"
                   asp-area="Property"
                   asp-controller="PropertyDashboard"
                   asp-action="Residents"
                   asp-route-companySlug="@propertyLayoutVm.CompanySlug"
                   asp-route-customerSlug="@propertyLayoutVm.CustomerSlug"
                   asp-route-propertySlug="@propertyLayoutVm.PropertySlug">@App.Resources.Views.UiText.Residents</a>

                <a class="management-sidebar-link @(propertyLayoutVm.CurrentSection == "Tickets" ? "active" : "")"
                   asp-area="Property"
                   asp-controller="PropertyDashboard"
                   asp-action="Tickets"
                   asp-route-companySlug="@propertyLayoutVm.CompanySlug"
                   asp-route-customerSlug="@propertyLayoutVm.CustomerSlug"
                   asp-route-propertySlug="@propertyLayoutVm.PropertySlug">@App.Resources.Views.UiText.Tickets</a>
            </nav>

            <div class="management-sidebar-footer">
                <a class="management-btn management-sidebar-cta" asp-area="" asp-controller="Onboarding" asp-action="Index" asp-route-showChooser="true">@App.Resources.Views.UiText.NewContext</a>
                <div class="management-language-title">@App.Resources.Views.UiText.Language (@sharedLayoutVm.CurrentUiCultureName)</div>
                <div class="management-language-list">
                    @foreach (var item in sharedLayoutVm.CultureOptions)
                    {
                        <a class="management-language-link @(item.IsCurrent ? "active" : "")"
                           asp-area=""
                           asp-controller="Home"
                           asp-action="SetLanguage"
                           asp-route-culture="@item.Value"
                           asp-route-returnUrl="@sharedLayoutVm.CurrentPathAndQuery">
                            @item.Text
                        </a>
                    }
                </div>
                <a class="management-sidebar-link" asp-area="" asp-controller="Home" asp-action="Privacy">@App.Resources.Views.UiText.Privacy</a>
            </div>
        </aside>

        <main class="management-main">
            <h1 class="management-page-title">@ViewData["Title"]</h1>
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    private static string T(string key, string fallback)
    {
        return App.Resources.Views.UiText.ResourceManager.GetString(key) ?? fallback;
    }
}

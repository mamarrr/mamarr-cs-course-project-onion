@model WebApp.ViewModels.Management.CustomerProperties.PropertyDashboardPageViewModel
@{
    var currentSectionLabel = (ViewData["CurrentSectionLabel"] as string) ?? App.Resources.Views.UiText.Dashboard;
}

<section class="management-card mb-4">
    <p class="management-eyebrow mb-2">@T("PropertyDashboard", "Property dashboard")</p>
    <h2 class="mb-1">@Model.PropertyName</h2>
    <p class="management-muted mb-0">@string.Format(T("PropertyDashboardIntro", "Property workspace for {0} in customer {1} ({2})."), Model.PropertyName, Model.CustomerName, Model.CompanyName)</p>
</section>

<nav class="management-tabs mb-4" aria-label="Property navigation">
    <a class="management-tab @(Model.CurrentSection == "Dashboard" ? "active" : string.Empty)"
       asp-area="Property"
       asp-controller="PropertyDashboard"
       asp-action="Index"
       asp-route-companySlug="@Model.CompanySlug"
       asp-route-customerSlug="@Model.CustomerSlug"
       asp-route-propertySlug="@Model.PropertySlug">@App.Resources.Views.UiText.Dashboard</a>

    <a class="management-tab @(Model.CurrentSection == "Profile" ? "active" : string.Empty)"
       asp-area="Property"
       asp-controller="PropertyDashboard"
       asp-action="Profile"
       asp-route-companySlug="@Model.CompanySlug"
       asp-route-customerSlug="@Model.CustomerSlug"
       asp-route-propertySlug="@Model.PropertySlug">@T("Profile", "Profile")</a>

    <a class="management-tab @(Model.CurrentSection == "Units" ? "active" : string.Empty)"
       asp-area="Property"
       asp-controller="PropertyDashboard"
       asp-action="Units"
       asp-route-companySlug="@Model.CompanySlug"
       asp-route-customerSlug="@Model.CustomerSlug"
       asp-route-propertySlug="@Model.PropertySlug">@T("Units", "Units")</a>

    <a class="management-tab @(Model.CurrentSection == "Residents" ? "active" : string.Empty)"
       asp-area="Property"
       asp-controller="PropertyDashboard"
       asp-action="Residents"
       asp-route-companySlug="@Model.CompanySlug"
       asp-route-customerSlug="@Model.CustomerSlug"
       asp-route-propertySlug="@Model.PropertySlug">@App.Resources.Views.UiText.Residents</a>

    <a class="management-tab @(Model.CurrentSection == "Tickets" ? "active" : string.Empty)"
       asp-area="Property"
       asp-controller="PropertyDashboard"
       asp-action="Tickets"
       asp-route-companySlug="@Model.CompanySlug"
       asp-route-customerSlug="@Model.CustomerSlug"
       asp-route-propertySlug="@Model.PropertySlug">@App.Resources.Views.UiText.Tickets</a>
</nav>

<section class="management-card">
    <h3>@currentSectionLabel</h3>
    <p class="management-muted mb-0">@string.Format(T("PropertySectionPlaceholder", "{0} content is planned and will be added in a later increment."), currentSectionLabel)</p>
</section>

@functions {
    private static string T(string key, string fallback)
    {
        return App.Resources.Views.UiText.ResourceManager.GetString(key) ?? fallback;
    }
}

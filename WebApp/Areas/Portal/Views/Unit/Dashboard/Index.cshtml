@model WebApp.ViewModels.Unit.DashboardPageViewModel
@{
    var currentSectionLabel = (ViewData["CurrentSectionLabel"] as string) ?? App.Resources.Views.UiText.Dashboard;
}

<section class="management-card mb-4">
    <p class="management-eyebrow mb-2">@App.Resources.Views.UiText.UnitDashboard</p>
    <h2 class="mb-1">@Model.UnitName</h2>
    <p class="management-muted mb-0">@string.Format(App.Resources.Views.UiText.UnitDashboardIntro, Model.UnitName, Model.PropertyName, Model.CustomerName, Model.CompanyName)</p>
</section>

<section class="management-card">
    <h3>@currentSectionLabel</h3>
    <p class="management-muted mb-0">@string.Format(App.Resources.Views.UiText.UnitSectionPlaceholder, currentSectionLabel)</p>
</section>


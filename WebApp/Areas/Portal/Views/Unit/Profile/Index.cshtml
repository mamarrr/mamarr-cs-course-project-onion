@model WebApp.ViewModels.Unit.ProfilePageViewModel
@{
    Layout = "~/Views/Shared/_AppChromeLayout.cshtml";
}

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
}

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<div class="management-grid management-grid-2">
    <section class="management-card" style="grid-column: 1 / -1;">
        <p class="management-eyebrow mb-2">@App.Resources.Views.UiText.Profile</p>
        <h2 class="mb-1">@Model.UnitName</h2>
        <p class="management-muted mb-0">@App.Resources.Views.UiText.UnitProfileDescription</p>
    </section>

    <section class="management-card">
        <h3>@App.Resources.Views.UiText.Edit</h3>
        <form method="post" asp-action="Edit" asp-route-companySlug="@Model.CompanySlug" asp-route-customerSlug="@Model.CustomerSlug" asp-route-propertySlug="@Model.PropertySlug" asp-route-unitSlug="@Model.UnitSlug">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Edit.UnitNr" class="form-label"></label>
                <input asp-for="Edit.UnitNr" class="form-control" />
                <span asp-validation-for="Edit.UnitNr" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Edit.FloorNr" class="form-label"></label>
                <input asp-for="Edit.FloorNr" class="form-control" />
                <span asp-validation-for="Edit.FloorNr" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Edit.SizeM2" class="form-label"></label>
                <input asp-for="Edit.SizeM2" class="form-control" />
                <span asp-validation-for="Edit.SizeM2" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Edit.Notes" class="form-label"></label>
                <textarea asp-for="Edit.Notes" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Edit.Notes" class="text-danger"></span>
            </div>
            <button type="submit" class="management-btn">@App.Resources.Views.UiText.SaveChanges</button>
        </form>
    </section>

    <section class="management-card border border-danger-subtle">
        <h3 class="text-danger">@App.Resources.Views.UiText.DangerZone</h3>
        <p>@App.Resources.Views.UiText.ProfileDeleteWarning</p>
        <p class="management-muted">@string.Format(App.Resources.Views.UiText.TypeValueToConfirmDelete, Model.UnitName)</p>
        <form method="post" asp-action="Delete" asp-route-companySlug="@Model.CompanySlug" asp-route-customerSlug="@Model.CustomerSlug" asp-route-propertySlug="@Model.PropertySlug" asp-route-unitSlug="@Model.UnitSlug">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Edit.UnitNr" />
            <input type="hidden" asp-for="Edit.FloorNr" />
            <input type="hidden" asp-for="Edit.SizeM2" />
            <input type="hidden" asp-for="Edit.Notes" />
            <div class="mb-3">
                <label asp-for="Edit.DeleteConfirmation" class="form-label"></label>
                <input asp-for="Edit.DeleteConfirmation" class="form-control" autocomplete="off" />
                <span asp-validation-for="Edit.DeleteConfirmation" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-danger">@App.Resources.Views.UiText.Delete</button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

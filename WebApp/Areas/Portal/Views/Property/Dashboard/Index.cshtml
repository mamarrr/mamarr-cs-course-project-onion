@model WebApp.ViewModels.Property.DashboardPageViewModel
@using WebApp.UI.Routing

<section class="management-card mb-4">
    <p class="management-eyebrow mb-2">@App.Resources.Views.UiText.PropertyDashboard</p>
    <h2 class="mb-1">@Model.Dashboard.PropertyName</h2>
    <p class="management-muted mb-0">@Model.Dashboard.PropertyTypeLabel</p>
    <p class="management-muted mb-0">@Model.Dashboard.AddressLine, @Model.Dashboard.City @Model.Dashboard.PostalCode</p>
    <div class="mt-3">
        <a class="management-btn secondary" asp-route="@PortalRouteNames.PropertyProfile" asp-route-companySlug="@Model.CompanySlug" asp-route-customerSlug="@Model.CustomerSlug" asp-route-propertySlug="@Model.PropertySlug">@App.Resources.Views.UiText.Profile</a>
    </div>
</section>

<div class="management-grid management-grid-3 mb-4">
    @foreach (var metric in Model.Dashboard.UnitMetrics)
    {
        <section class="management-kpi">
            <span>@metric.Label</span>
            <strong>@metric.Value</strong>
        </section>
    }
    @foreach (var metric in Model.Dashboard.ResidentLeaseMetrics)
    {
        <section class="management-kpi">
            <span>@metric.Label</span>
            <strong>@metric.Value</strong>
        </section>
    }
</div>

<div class="management-grid management-grid-2">
    <section class="management-card">
        <h3>@App.Resources.Views.UiText.Tickets</h3>
        <div class="management-grid management-grid-2 mb-3">
            @foreach (var metric in Model.Dashboard.TicketMetrics)
            {
                <div class="management-kpi">
                    <span>@metric.Label</span>
                    <strong>@metric.Value</strong>
                </div>
            }
        </div>
        <h4>@T("TicketsByStatus", "Tickets by status")</h4>
        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var item in Model.Dashboard.TicketsByStatus)
            {
                <span class="management-badge">@item.Label: @item.Count</span>
            }
        </div>
        <h4>@T("ByPriority", "By priority")</h4>
        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var item in Model.Dashboard.TicketsByPriority)
            {
                <span class="management-badge">@item.Label: @item.Count</span>
            }
        </div>
        <h4>@T("ByCategory", "By category")</h4>
        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var item in Model.Dashboard.TicketsByCategory)
            {
                <span class="management-badge">@item.Label: @item.Count</span>
            }
        </div>
        @if (Model.Dashboard.RecentTickets.Count == 0)
        {
            <p class="management-muted">@T("NoTicketsToShow", "No tickets to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table">
                    <tbody>
                    @foreach (var ticket in Model.Dashboard.RecentTickets)
                    {
                        <tr>
                            <td><a asp-route="@PortalRouteNames.ManagementTicketDetails" asp-route-companySlug="@Model.CompanySlug" asp-route-ticketId="@ticket.TicketId">@ticket.TicketNr</a></td>
                            <td>@ticket.Title</td>
                            <td><span class="management-badge">@ticket.StatusLabel</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="management-card">
        <h3>@T("ResidentsAndLeases", "Residents and leases")</h3>
        @if (Model.Dashboard.CurrentLeases.Count == 0)
        {
            <p class="management-muted">@T("NoActiveLeasesToShow", "No active leases to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table">
                    <tbody>
                    @foreach (var lease in Model.Dashboard.CurrentLeases)
                    {
                        <tr>
                            <td>@lease.UnitNr</td>
                            <td>@lease.ResidentName</td>
                            <td>@lease.RoleLabel</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="management-card">
        <h3>@T("ScheduledWork", "Scheduled work")</h3>
        <h4>@T("UpcomingWork", "Upcoming work")</h4>
        @if (Model.Dashboard.UpcomingWork.Count == 0)
        {
            <p class="management-muted">@T("NoWorkToShow", "No work to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table"><tbody>
                @foreach (var work in Model.Dashboard.UpcomingWork)
                {
                    <tr><td><a asp-route="@PortalRouteNames.ManagementTicketDetails" asp-route-companySlug="@Model.CompanySlug" asp-route-ticketId="@work.TicketId">@work.TicketNr</a></td><td>@work.VendorName</td><td><span class="management-badge">@work.WorkStatusLabel</span></td></tr>
                }
                </tbody></table>
            </div>
        }
        <h4 class="mt-3">@T("DelayedWork", "Delayed work")</h4>
        @if (Model.Dashboard.DelayedWork.Count == 0)
        {
            <p class="management-muted">@T("NoWorkToShow", "No work to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table"><tbody>
                @foreach (var work in Model.Dashboard.DelayedWork)
                {
                    <tr><td><a asp-route="@PortalRouteNames.ManagementTicketDetails" asp-route-companySlug="@Model.CompanySlug" asp-route-ticketId="@work.TicketId">@work.TicketNr</a></td><td>@work.VendorName</td><td><span class="management-badge">@work.WorkStatusLabel</span></td></tr>
                }
                </tbody></table>
            </div>
        }
        <h4 class="mt-3">@T("RecentlyCompletedWork", "Recently completed work")</h4>
        @if (Model.Dashboard.RecentlyCompletedWork.Count == 0)
        {
            <p class="management-muted">@T("NoWorkToShow", "No work to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table"><tbody>
                @foreach (var work in Model.Dashboard.RecentlyCompletedWork)
                {
                    <tr><td><a asp-route="@PortalRouteNames.ManagementTicketDetails" asp-route-companySlug="@Model.CompanySlug" asp-route-ticketId="@work.TicketId">@work.TicketNr</a></td><td>@work.VendorName</td><td><span class="management-badge">@work.WorkStatusLabel</span></td></tr>
                }
                </tbody></table>
            </div>
        }
    </section>

    <section class="management-card">
        <h3>@T("UnitPreview", "Unit preview")</h3>
        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var item in Model.Dashboard.UnitsByFloor)
            {
                <span class="management-badge">@T("Floor", "Floor") @item.Label: @item.Count</span>
            }
        </div>
        @if (Model.Dashboard.UnitPreview.Count == 0)
        {
            <p class="management-muted">@T("NoUnitsToShow", "No units to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table">
                    <tbody>
                    @foreach (var unit in Model.Dashboard.UnitPreview)
                    {
                        <tr>
                            <td><a asp-route="@PortalRouteNames.UnitDashboard" asp-route-companySlug="@Model.CompanySlug" asp-route-customerSlug="@Model.CustomerSlug" asp-route-propertySlug="@Model.PropertySlug" asp-route-unitSlug="@unit.UnitSlug">@unit.UnitNr</a></td>
                            <td>@(unit.FloorNr?.ToString() ?? "")</td>
                            <td>@(unit.SizeM2?.ToString("0.##") ?? "")</td>
                            <td>@(unit.HasActiveLease ? T("Occupied", "Occupied") : T("Vacant", "Vacant"))</td>
                            <td>@unit.OpenTicketCount</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@functions {
    private static string T(string key, string fallback) =>
        App.Resources.Views.UiText.ResourceManager.GetString(key) ?? fallback;
}

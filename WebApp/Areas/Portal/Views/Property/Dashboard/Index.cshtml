@model WebApp.ViewModels.Property.DashboardPageViewModel

<section class="management-card mb-4">
    <p class="management-eyebrow mb-2">@App.Resources.Views.UiText.PropertyDashboard</p>
    <h2 class="mb-1">@Model.PropertyName</h2>
    <p class="management-muted mb-0">@string.Format(App.Resources.Views.UiText.PropertyDashboardIntro, Model.PropertyName, Model.CustomerName, Model.CompanyName)</p>
</section>

<section class="management-card">
    <h3>@Model.CurrentSectionLabel</h3>
    <p class="management-muted mb-0">@string.Format(App.Resources.Views.UiText.PropertySectionPlaceholder, Model.CurrentSectionLabel)</p>
</section>


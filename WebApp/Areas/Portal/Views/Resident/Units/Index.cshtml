@model WebApp.ViewModels.Resident.UnitsPageViewModel
@using App.Resources.Views
@using App.Resources.Domain
@{
    ViewData["Title"] = UiText.Units;

    string UnitLabel(WebApp.ViewModels.Resident.ResidentLeaseUnitOptionViewModel unit)
    {
        var floorText = unit.FloorNr.HasValue
            ? $", {UiText.FloorNr} {unit.FloorNr.Value}"
            : string.Empty;
        return $"{UiText.Unit} {unit.UnitNr}{floorText}";
    }

    var propertySelection = Model.PropertySearchResults.FirstOrDefault(x => x.PropertyId == Model.AddLease.PropertyId);
}

<div class="management-grid management-grid-2">
    <section class="management-card" style="grid-column: 1 / -1;">
        <p class="management-eyebrow mb-2">@UiText.Units</p>
        <h2 class="mb-1">@Model.ResidentDisplayName</h2>
        <p class="management-muted mb-0">@string.Format(UiText.ResidentDashboardIntro, Model.ResidentDisplayName, Model.CompanyName)</p>
        @if (!string.IsNullOrWhiteSpace(Model.ResidentSupportingText))
        {
            <p class="management-muted mb-0">@Model.ResidentSupportingText</p>
        }
    </section>

    <section class="management-card">
        <h2>@UiText.AddLease</h2>
        <p class="management-muted">@UiText.ResidentLeaseAddDescription</p>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <form method="get" asp-action="Index" asp-route-companySlug="@Model.CompanySlug" asp-route-residentIdCode="@Model.ResidentIdCode" class="row g-3 mb-4">
            <div class="col-md-9">
                <label asp-for="AddLease.PropertySearchTerm" class="form-label"></label>
                <input asp-for="AddLease.PropertySearchTerm" class="form-control" />
                <span asp-validation-for="AddLease.PropertySearchTerm" class="text-danger"></span>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="management-btn w-100">@UiText.SearchProperties</button>
            </div>
            <input type="hidden" asp-for="AddLease.PropertyId" />
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.AddLease.PropertySearchTerm))
        {
            if (Model.PropertySearchResults.Count == 0)
            {
                <div class="border rounded p-3 bg-light-subtle mb-4">
                    <strong>@UiText.NoPropertiesFound</strong>
                    <p class="management-muted mb-0">@UiText.NoPropertiesFoundDescription</p>
                </div>
            }
            else
            {
                <div class="border rounded p-3 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>@UiText.PropertyResults</strong>
                        <span class="management-muted">@Model.PropertySearchResults.Count</span>
                    </div>
                    <div class="list-group">
                        @foreach (var property in Model.PropertySearchResults)
                        {
                            var isSelected = Model.AddLease.PropertyId == property.PropertyId;
                            <a class="list-group-item list-group-item-action @(isSelected ? "active" : string.Empty)"
                               asp-action="Index"
                               asp-route-companySlug="@Model.CompanySlug"
                               asp-route-residentIdCode="@Model.ResidentIdCode"
                               asp-route-AddLease.PropertySearchTerm="@Model.AddLease.PropertySearchTerm"
                               asp-route-AddLease.PropertyId="@property.PropertyId">
                                <div class="fw-semibold">@property.PropertyName</div>
                                <div>@property.AddressLine, @property.City @property.PostalCode</div>
                                <div class="small @(isSelected ? "text-white-50" : "text-muted")">@property.CustomerName</div>
                            </a>
                        }
                    </div>
                </div>
            }
        }

        <form method="post" asp-action="Add" asp-route-companySlug="@Model.CompanySlug" asp-route-residentIdCode="@Model.ResidentIdCode" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AddLease.PropertySearchTerm" />
            <input type="hidden" asp-for="AddLease.PropertyId" />

            <div class="col-12">
                <label class="form-label">@UiText.Property</label>
                @if (propertySelection == null)
                {
                    <div class="form-control bg-light-subtle">@UiText.NoValuePlaceholder</div>
                }
                else
                {
                    <div class="form-control bg-light-subtle">
                        <strong>@propertySelection.PropertyName</strong><br />
                        <span>@propertySelection.AddressLine, @propertySelection.City @propertySelection.PostalCode</span>
                    </div>
                }
            </div>

            <div class="col-md-6">
                <label asp-for="AddLease.UnitId" class="form-label"></label>
                <select asp-for="AddLease.UnitId" class="form-select">
                    <option value="">@UiText.SelectUnit</option>
                    @foreach (var unit in Model.UnitOptions)
                    {
                        <option value="@unit.UnitId">@UnitLabel(unit)</option>
                    }
                </select>
                <span asp-validation-for="AddLease.UnitId" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="AddLease.LeaseRoleId" class="form-label"></label>
                <select asp-for="AddLease.LeaseRoleId" class="form-select">
                    <option value="">@UiText.SelectLeaseRole</option>
                    @foreach (var role in Model.LeaseRoleOptions)
                    {
                        <option value="@role.LeaseRoleId">@role.Label</option>
                    }
                </select>
                <span asp-validation-for="AddLease.LeaseRoleId" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="AddLease.StartDate" class="form-label"></label>
                <input asp-for="AddLease.StartDate" class="form-control" type="date" />
                <span asp-validation-for="AddLease.StartDate" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="AddLease.EndDate" class="form-label"></label>
                <input asp-for="AddLease.EndDate" class="form-control" type="date" />
                <span asp-validation-for="AddLease.EndDate" class="text-danger"></span>
            </div>
            

            <div class="col-12">
                <label asp-for="AddLease.Notes" class="form-label"></label>
                <textarea asp-for="AddLease.Notes" class="form-control" rows="4"></textarea>
                <span asp-validation-for="AddLease.Notes" class="text-danger"></span>
            </div>

            <div class="col-12">
                <button type="submit" class="management-btn">@UiText.AddLease</button>
            </div>
        </form>
    </section>

    <section class="management-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="mb-1">@UiText.CurrentLeases</h2>
                <p class="management-muted mb-0">@UiText.ResidentLeaseListDescription</p>
            </div>
            <span class="management-badge @(Model.Leases.Count > 0 ? "success" : "warning")">
                @string.Format(UiText.ActiveRecords, Model.Leases.Count)
            </span>
        </div>

        @if (Model.Leases.Count == 0)
        {
            <div class="border rounded p-3 bg-light-subtle">
                <strong>@UiText.NoUnitsFound</strong>
                <p class="management-muted mb-0">@UiText.NoResidentLeasesFoundDescription</p>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var lease in Model.Leases)
                {
                    var isEditing = Model.ActiveEditLeaseId == lease.LeaseId;
                    <article class="border rounded p-3">
                        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                            <div>
                                <div class="management-eyebrow mb-1">@lease.PropertyName</div>
                                <h3 class="h5 mb-1">@UiText.Unit @lease.UnitNr</h3>
                                <div class="management-muted mb-2">@lease.LeaseRoleLabel</div>
                                <div class="small text-muted">
                                    @UiText.StartDate: @lease.StartDate.ToString("yyyy-MM-dd")
                                    @if (lease.EndDate.HasValue)
                                    {
                                        <span class="ms-2">@UiText.EndDate: @lease.EndDate.Value.ToString("yyyy-MM-dd")</span>
                                    }
                                </div>
                            </div>
                            <div class="d-flex flex-column align-items-lg-end gap-2">
                                <div class="d-flex gap-2">
                                    <a class="management-btn ghost"
                                       asp-action="Index"
                                       asp-route-companySlug="@Model.CompanySlug"
                                       asp-route-residentIdCode="@Model.ResidentIdCode"
                                       asp-route-AddLease.PropertySearchTerm="@Model.AddLease.PropertySearchTerm"
                                       asp-route-AddLease.PropertyId="@Model.AddLease.PropertyId"
                                       asp-route-ActiveEditLeaseId="@lease.LeaseId">@UiText.Edit</a>
                                    <form method="post" asp-action="Delete" asp-route-companySlug="@Model.CompanySlug" asp-route-residentIdCode="@Model.ResidentIdCode" asp-route-leaseId="@lease.LeaseId">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="management-btn ghost">@UiText.Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(lease.Notes))
                        {
                            <div class="mt-3">
                                <strong>@UiText.Notes</strong>
                                <p class="mb-0">@lease.Notes</p>
                            </div>
                        }

                        @if (isEditing)
                        {
                            <hr />
                            <form method="post" asp-action="Edit" asp-route-companySlug="@Model.CompanySlug" asp-route-residentIdCode="@Model.ResidentIdCode" asp-route-leaseId="@lease.LeaseId" class="row g-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="EditLease.LeaseId" value="@lease.LeaseId" />

                                <div class="col-md-6">
                                    <label asp-for="EditLease.LeaseRoleId" class="form-label"></label>
                                    <select asp-for="EditLease.LeaseRoleId" class="form-select">
                                        <option value="">@UiText.SelectLeaseRole</option>
                                        @foreach (var role in Model.LeaseRoleOptions)
                                        {
                                            var selectedRoleId = Model.EditLease.LeaseId == lease.LeaseId && Model.EditLease.LeaseRoleId.HasValue
                                                ? Model.EditLease.LeaseRoleId.Value
                                                : lease.LeaseRoleId;
                                            <option value="@role.LeaseRoleId" selected="@(selectedRoleId == role.LeaseRoleId)">@role.Label</option>
                                        }
                                    </select>
                                    <span asp-validation-for="EditLease.LeaseRoleId" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="EditLease.StartDate" class="form-label"></label>
                                    <input asp-for="EditLease.StartDate" class="form-control" type="date" value="@((Model.EditLease.LeaseId == lease.LeaseId ? Model.EditLease.StartDate : lease.StartDate).ToString("yyyy-MM-dd"))" />
                                    <span asp-validation-for="EditLease.StartDate" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="EditLease.EndDate" class="form-label"></label>
                                    <input asp-for="EditLease.EndDate" class="form-control" type="date" value="@((Model.EditLease.LeaseId == lease.LeaseId ? Model.EditLease.EndDate : lease.EndDate)?.ToString("yyyy-MM-dd"))" />
                                    <span asp-validation-for="EditLease.EndDate" class="text-danger"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="EditLease.Notes" class="form-label"></label>
                                    <textarea asp-for="EditLease.Notes" class="form-control" rows="3">@(Model.EditLease.LeaseId == lease.LeaseId ? Model.EditLease.Notes : lease.Notes)</textarea>
                                    <span asp-validation-for="EditLease.Notes" class="text-danger"></span>
                                </div>

                                <div class="col-12 d-flex gap-2">
                                    <button type="submit" class="management-btn">@UiText.SaveChanges</button>
                                    <a class="management-btn ghost" asp-action="Index" asp-route-companySlug="@Model.CompanySlug" asp-route-residentIdCode="@Model.ResidentIdCode">@UiText.Cancel</a>
                                </div>
                            </form>
                        }
                    </article>
                }
            </div>
        }
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model WebApp.ViewModels.Resident.DashboardPageViewModel
@using WebApp.UI.Routing

<section class="management-card mb-4">
    <p class="management-eyebrow mb-2">@App.Resources.Views.UiText.ResidentDashboard</p>
    <h2 class="mb-1">@Model.Dashboard.FullName</h2>
    <p class="management-muted mb-0">@Model.Dashboard.IdCode</p>
    <p class="management-muted mb-0">@T("PreferredLanguage", "Preferred language"): @(Model.Dashboard.PreferredLanguage ?? "")</p>
    <div class="mt-3">
        <a class="management-btn secondary" asp-route="@PortalRouteNames.ResidentProfile" asp-route-companySlug="@Model.CompanySlug" asp-route-residentIdCode="@Model.ResidentIdCode">@App.Resources.Views.UiText.Profile</a>
    </div>
</section>

<div class="management-grid management-grid-2">
    <section class="management-card">
        <h3>@T("ActiveLeases", "Active leases")</h3>
        @if (Model.Dashboard.ActiveLeases.Count == 0)
        {
            <p class="management-muted">@T("NoActiveLeasesToShow", "No active leases to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table"><tbody>
                @foreach (var lease in Model.Dashboard.ActiveLeases)
                {
                    <tr>
                        <td>@lease.PropertyName</td>
                        <td>@lease.UnitNr</td>
                        <td>@lease.RoleLabel</td>
                    </tr>
                }
                </tbody></table>
            </div>
        }
    </section>

    <section class="management-card">
        <h3>@App.Resources.Views.UiText.Tickets</h3>
        <div class="management-grid management-grid-3 mb-3">
            @foreach (var metric in Model.Dashboard.TicketMetrics)
            {
                <div class="management-kpi">
                    <span>@metric.Label</span>
                    <strong>@metric.Value</strong>
                </div>
            }
        </div>
        @if (Model.Dashboard.RecentTickets.Count == 0)
        {
            <p class="management-muted">@T("NoTicketsToShow", "No tickets to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table"><tbody>
                @foreach (var ticket in Model.Dashboard.RecentTickets)
                {
                    <tr>
                        <td><a asp-route="@PortalRouteNames.ManagementTicketDetails" asp-route-companySlug="@Model.CompanySlug" asp-route-ticketId="@ticket.TicketId">@ticket.TicketNr</a></td>
                        <td>@ticket.Title</td>
                        <td><span class="management-badge">@ticket.StatusLabel</span></td>
                    </tr>
                }
                </tbody></table>
            </div>
        }
    </section>

    <section class="management-card">
        <h3>@T("Contacts", "Contacts")</h3>
        @if (Model.Dashboard.ContactSummary.PrimaryContact is null)
        {
            <p class="management-muted">@T("NoPrimaryContact", "No primary contact.")</p>
        }
        else
        {
            <strong>@Model.Dashboard.ContactSummary.PrimaryContact.ContactTypeLabel</strong>
            <p class="management-muted">@Model.Dashboard.ContactSummary.PrimaryContact.ContactValue</p>
        }
        <div class="d-flex flex-wrap gap-2">
            @foreach (var item in Model.Dashboard.ContactSummary.ContactMethodCounts)
            {
                <span class="management-badge">@item.Label: @item.Count</span>
            }
        </div>
    </section>

    <section class="management-card">
        <h3>@T("Representations", "Representations")</h3>
        @if (Model.Dashboard.Representations.Count == 0)
        {
            <p class="management-muted">@T("NoRepresentationsToShow", "No representations to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table"><tbody>
                @foreach (var representation in Model.Dashboard.Representations)
                {
                    <tr>
                        <td>@representation.CustomerName</td>
                        <td>@representation.RoleLabel</td>
                        <td>@representation.ValidFrom.ToString("d") - @(representation.ValidTo?.ToString("d") ?? "")</td>
                    </tr>
                }
                </tbody></table>
            </div>
        }
    </section>
</div>

@functions {
    private static string T(string key, string fallback) =>
        App.Resources.Views.UiText.ResourceManager.GetString(key) ?? fallback;
}

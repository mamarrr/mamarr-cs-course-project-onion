@model WebApp.ViewModels.Resident.DashboardPageViewModel
@{
    var currentSectionLabel = (ViewData["CurrentSectionLabel"] as string) ?? App.Resources.Views.UiText.Dashboard;
}

<section class="management-card mb-4">
    <p class="management-eyebrow mb-2">@App.Resources.Views.UiText.ResidentDashboard</p>
    <h2 class="mb-1">@Model.ResidentDisplayName</h2>
    <p class="management-muted mb-0">@string.Format(App.Resources.Views.UiText.ResidentDashboardIntro, Model.ResidentDisplayName, Model.CompanyName)</p>
    @if (!string.IsNullOrWhiteSpace(Model.ResidentSupportingText))
    {
        <p class="management-muted mb-0">@Model.ResidentSupportingText</p>
    }
</section>

<section class="management-card">
    <h3>@currentSectionLabel</h3>
    <p class="management-muted mb-0">@string.Format(App.Resources.Views.UiText.ResidentSectionPlaceholder, currentSectionLabel)</p>
</section>


@model WebApp.ViewModels.Management.WorkLogs.WorkLogIndexViewModel
@using App.Resources.Views
@{
    string Empty(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
    string T(string key, string fallback) => UiText.ResourceManager.GetString(key) ?? fallback;
}

<div class="management-grid">
    @if (TempData["ManagementWorkLogSuccess"] is string successMessage)
    {
        <div class="alert alert-success" role="alert">@successMessage</div>
    }

    @if (TempData["ManagementWorkLogError"] is string errorMessage)
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <section class="management-card">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-start">
            <div>
                <p class="management-eyebrow mb-2">@Model.TicketNr</p>
                <h2 class="mb-1">@T("WorkLogs", "Work logs")</h2>
                <p class="management-muted mb-0">@Model.VendorName - @Model.WorkStatusLabel</p>
            </div>
            <div class="d-flex gap-2">
                <a class="management-btn"
                   asp-action="Create"
                   asp-route-companySlug="@Model.CompanySlug"
                   asp-route-ticketId="@Model.TicketId"
                   asp-route-scheduledWorkId="@Model.ScheduledWorkId">@T("CreateWorkLog", "Add work log")</a>
                <a class="btn btn-outline-secondary"
                   asp-controller="ScheduledWorks"
                   asp-action="Details"
                   asp-route-companySlug="@Model.CompanySlug"
                   asp-route-ticketId="@Model.TicketId"
                   asp-route-scheduledWorkId="@Model.ScheduledWorkId">@T("BackToScheduledWork", "Back to scheduled work")</a>
            </div>
        </div>
    </section>

    <section class="management-card">
        <div class="row g-3">
            <div class="col-md-3">
                <p class="management-eyebrow mb-1">@T("LogCount", "Logs")</p>
                <h3 class="mb-0">@Model.Totals.Count</h3>
            </div>
            <div class="col-md-3">
                <p class="management-eyebrow mb-1">@T("Hours", "Hours")</p>
                <h3 class="mb-0">@Model.Totals.Hours</h3>
            </div>
            @if (Model.CanViewCosts)
            {
                <div class="col-md-3">
                    <p class="management-eyebrow mb-1">@T("MaterialCost", "Material cost")</p>
                    <h3 class="mb-0">@Model.Totals.MaterialCost.ToString("C")</h3>
                </div>
                <div class="col-md-3">
                    <p class="management-eyebrow mb-1">@T("TotalCost", "Total cost")</p>
                    <h3 class="mb-0">@Model.Totals.TotalCost.ToString("C")</h3>
                </div>
            }
        </div>
    </section>

    <section class="management-card">
        @if (Model.Items.Count == 0)
        {
            <p class="management-muted mb-0">@T("NoWorkLogs", "No work logs have been added yet.")</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                    <tr>
                        <th>@T("WorkWindow", "Work window")</th>
                        <th>@T("Hours", "Hours")</th>
                        @if (Model.CanViewCosts)
                        {
                            <th>@T("MaterialCost", "Material cost")</th>
                            <th>@T("LaborCost", "Labor cost")</th>
                        }
                        <th>@T("LoggedBy", "Logged by")</th>
                        <th>@T("Description", "Description")</th>
                        <th class="text-end">@UiText.Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@(item.WorkStart?.ToString("g") ?? "-") - @(item.WorkEnd?.ToString("g") ?? "-")</td>
                            <td>@(item.Hours?.ToString("0.##") ?? "-")</td>
                            @if (Model.CanViewCosts)
                            {
                                <td>@(item.MaterialCost?.ToString("C") ?? "-")</td>
                                <td>@(item.LaborCost?.ToString("C") ?? "-")</td>
                            }
                            <td>@item.AppUserName</td>
                            <td>@Empty(item.Description)</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-sm btn-outline-secondary"
                                       asp-action="Edit"
                                       asp-route-companySlug="@Model.CompanySlug"
                                       asp-route-ticketId="@Model.TicketId"
                                       asp-route-scheduledWorkId="@Model.ScheduledWorkId"
                                       asp-route-workLogId="@item.WorkLogId">@UiText.Edit</a>
                                    <a class="btn btn-sm btn-outline-danger"
                                       asp-action="Delete"
                                       asp-route-companySlug="@Model.CompanySlug"
                                       asp-route-ticketId="@Model.TicketId"
                                       asp-route-scheduledWorkId="@Model.ScheduledWorkId"
                                       asp-route-workLogId="@item.WorkLogId">@UiText.Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

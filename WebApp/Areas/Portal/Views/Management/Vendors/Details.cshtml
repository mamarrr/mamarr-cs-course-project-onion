@model WebApp.ViewModels.Management.Vendors.VendorDetailsViewModel
@using App.Resources.Views

@functions {
    private static string T(string key, string fallback) => UiText.ResourceManager.GetString(key) ?? fallback;
}

<div class="management-grid management-grid-2">
    <section class="management-card" style="grid-column: 1 / -1;">
        @if (TempData["ManagementVendorsSuccess"] is string successMessage)
        {
            <div class="alert alert-success" role="alert">@successMessage</div>
        }

        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
            <div>
                <p class="management-eyebrow mb-2">@UiText.Vendors</p>
                <h2 class="mb-2">@Model.Name</h2>
                <p class="management-muted mb-0">@Model.RegistryCode</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit"
                   asp-route-companySlug="@Model.CompanySlug"
                   asp-route-vendorId="@Model.VendorId"
                   class="management-btn">@UiText.Edit</a>
                <a asp-action="Delete"
                   asp-route-companySlug="@Model.CompanySlug"
                   asp-route-vendorId="@Model.VendorId"
                   class="btn btn-outline-danger">@UiText.Delete</a>
            </div>
        </div>
    </section>

    <section class="management-card">
        <h2>@T("VendorProfile", "Vendor profile")</h2>
        <dl class="row mb-0">
            <dt class="col-sm-4">@UiText.Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>
            <dt class="col-sm-4">@UiText.RegistryCode</dt>
            <dd class="col-sm-8">@Model.RegistryCode</dd>
            <dt class="col-sm-4">@UiText.Notes</dt>
            <dd class="col-sm-8">@Model.Notes</dd>
        </dl>
    </section>

    <section class="management-card">
        <h2>@T("VendorWorkflow", "Vendor workflow")</h2>
        <div class="row g-3">
            <div class="col-6">
                <span class="management-badge success">@Model.ContactCount</span>
                <p class="management-muted mb-0">@UiText.Contacts</p>
            </div>
            <div class="col-6">
                <span class="management-badge success">@Model.ActiveCategoryCount</span>
                <p class="management-muted mb-0">@T("CategoryAssignments", "Category assignments")</p>
            </div>
            <div class="col-6">
                <span class="management-badge success">@Model.AssignedTicketCount</span>
                <p class="management-muted mb-0">@UiText.Tickets</p>
            </div>
            <div class="col-6">
                <span class="management-badge success">@Model.ScheduledWorkCount</span>
                <p class="management-muted mb-0">@T("ScheduledWork", "Scheduled work")</p>
            </div>
        </div>
        <div class="mt-3 d-flex flex-wrap gap-2">
            <a asp-controller="VendorCategories"
               asp-action="Index"
               asp-route-companySlug="@Model.CompanySlug"
               asp-route-vendorId="@Model.VendorId"
               class="management-btn">@T("ManageCategories", "Manage categories")</a>
            <a asp-route="portal.management.tickets"
               asp-route-companySlug="@Model.CompanySlug"
               asp-route-vendorId="@Model.VendorId"
               class="btn btn-outline-secondary">@T("ViewVendorTickets", "View tickets")</a>
            <span class="management-muted">@T("VendorContactsComingLater", "Contacts are handled in an upcoming workflow page.")</span>
        </div>
    </section>
</div>

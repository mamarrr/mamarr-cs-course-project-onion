@model WebApp.ViewModels.Management.Vendors.VendorFormPageViewModel
@using App.Resources.Views

<div class="col-md-6">
    <label asp-for="Form.Name" class="form-label"></label>
    <input asp-for="Form.Name" class="form-control" />
    <span asp-validation-for="Form.Name" class="text-danger"></span>
</div>
<div class="col-md-6">
    <label asp-for="Form.RegistryCode" class="form-label"></label>
    <input asp-for="Form.RegistryCode" class="form-control" />
    <span asp-validation-for="Form.RegistryCode" class="text-danger"></span>
</div>
<div class="col-12">
    <label asp-for="Form.Notes" class="form-label"></label>
    <textarea asp-for="Form.Notes" class="form-control" rows="5"></textarea>
    <span asp-validation-for="Form.Notes" class="text-danger"></span>
</div>

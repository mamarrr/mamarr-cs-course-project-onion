@model WebApp.ViewModels.Customer.CustomerDashboard.DashboardPageViewModel
@{
    Layout = "~/Views/Shared/_AppChromeLayout.cshtml";
}

<div class="management-grid management-grid-2">
    <section class="management-card" style="grid-column: 1 / -1;">
        <p class="management-eyebrow mb-2">@App.Resources.Views.UiText.CustomerDashboard</p>
        <h2 class="mb-2">@Model.CustomerName</h2>
        <p class="management-muted mb-0">@string.Format(App.Resources.Views.UiText.CustomerDashboardIntro, Model.CustomerName, Model.CompanyName)</p>
    </section>

    <section class="management-card">
        <h2>@Model.CurrentSectionLabel</h2>
        <p class="management-muted mb-0">@string.Format(App.Resources.Views.UiText.CustomerSectionPlaceholder, Model.CurrentSectionLabel)</p>
    </section>

    <section class="management-card">
        <h2>@App.Resources.Views.UiText.Status</h2>
        <span class="management-badge warning">@App.Resources.Views.UiText.InProgress</span>
    </section>
</div>


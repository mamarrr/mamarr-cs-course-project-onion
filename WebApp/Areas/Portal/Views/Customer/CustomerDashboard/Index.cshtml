@model WebApp.ViewModels.Customer.CustomerDashboard.DashboardPageViewModel
@using WebApp.UI.Routing
@{
    Layout = "~/Views/Shared/_AppChromeLayout.cshtml";
}

<section class="management-card mb-4">
    <p class="management-eyebrow mb-2">@App.Resources.Views.UiText.CustomerDashboard</p>
    <h2 class="mb-1">@Model.Dashboard.CustomerName</h2>
    <p class="management-muted mb-0">@Model.Dashboard.RegistryCode</p>
    <p class="management-muted mb-0">@Model.Dashboard.BillingEmail @Model.Dashboard.Phone</p>
    <div class="mt-3">
        <a class="management-btn secondary" asp-route="@PortalRouteNames.CustomerProfile" asp-route-companySlug="@Model.CompanySlug" asp-route-customerSlug="@Model.CustomerSlug">@App.Resources.Views.UiText.Profile</a>
    </div>
</section>

<div class="management-grid management-grid-3 mb-4">
    @foreach (var metric in Model.Dashboard.PortfolioMetrics)
    {
        <section class="management-kpi">
            <span>@metric.Label</span>
            <strong>@metric.Value</strong>
        </section>
    }
</div>

<div class="management-grid management-grid-2">
    <section class="management-card">
        <h3>@T("Tickets", "Tickets")</h3>
        <div class="management-grid management-grid-2 mb-3">
            @foreach (var metric in Model.Dashboard.TicketMetrics)
            {
                <div class="management-kpi">
                    <span>@metric.Label</span>
                    <strong>@metric.Value</strong>
                </div>
            }
        </div>
        <h4>@T("TicketsByProperty", "Tickets by property")</h4>
        @if (Model.Dashboard.TicketsByProperty.Count == 0)
        {
            <p class="management-muted">@T("NoItemsToShow", "No items to show.")</p>
        }
        else
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var item in Model.Dashboard.TicketsByProperty)
                {
                    <span class="management-badge">@item.Label: @item.Count</span>
                }
            </div>
        }
        <h4 class="mt-3">@T("RecentTickets", "Recent tickets")</h4>
        @if (Model.Dashboard.RecentTickets.Count == 0)
        {
            <p class="management-muted">@T("NoTicketsToShow", "No tickets to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table">
                    <tbody>
                    @foreach (var ticket in Model.Dashboard.RecentTickets)
                    {
                        <tr>
                            <td><a asp-route="@PortalRouteNames.ManagementTicketDetails" asp-route-companySlug="@Model.CompanySlug" asp-route-ticketId="@ticket.TicketId">@ticket.TicketNr</a></td>
                            <td>@ticket.Title</td>
                            <td><span class="management-badge">@ticket.StatusLabel</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="management-card">
        <h3>@T("Representatives", "Representatives")</h3>
        <div class="management-kpi mb-3">
            <span>@T("ActiveRepresentatives", "Active representatives")</span>
            <strong>@Model.Dashboard.ActiveRepresentativeCount</strong>
        </div>
        @if (Model.Dashboard.ActiveRepresentatives.Count == 0)
        {
            <p class="management-muted">@T("NoRepresentativesToShow", "No representatives to show.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table">
                    <tbody>
                    @foreach (var representative in Model.Dashboard.ActiveRepresentatives)
                    {
                        <tr>
                            <td>@representative.ResidentName</td>
                            <td>@representative.RoleLabel</td>
                            <td>@representative.ValidFrom.ToString("d") - @(representative.ValidTo?.ToString("d") ?? "")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="management-card" style="grid-column: 1 / -1;">
        <h3>@T("RecentActivity", "Recent activity")</h3>
        @if (Model.Dashboard.RecentActivity.Count == 0)
        {
            <p class="management-muted mb-0">@T("NoRecentActivity", "No recent activity.")</p>
        }
        else
        {
            <div class="management-table-responsive">
                <table class="management-table">
                    <tbody>
                    @foreach (var item in Model.Dashboard.RecentActivity)
                    {
                        <tr>
                            <td><span class="management-badge">@item.TypeLabel</span></td>
                            <td>@item.Label</td>
                            <td>@item.EventAt.ToLocalTime().ToString("g")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@functions {
    private static string T(string key, string fallback) =>
        App.Resources.Views.UiText.ResourceManager.GetString(key) ?? fallback;
}

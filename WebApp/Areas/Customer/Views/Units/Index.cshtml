@{
    var propertyId = (int?)ViewData["PropertyId"];
    ViewData["Title"] = "Customer Units Overview";
}

<div class="mock-alert info">
    @(propertyId.HasValue
        ? $"Showing portfolio units for property #{propertyId.Value}."
        : "Showing customer-visible units across the full portfolio.")
</div>

<section class="mock-card">
    <h2>Units</h2>
    <table class="mock-table">
        <thead>
        <tr>
            <th>Unit</th>
            <th>Property</th>
            <th>Open tickets</th>
            <th>Latest status</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>Unit 5B</td>
            <td><a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="201">Riverside 12</a></td>
            <td>2</td>
            <td><span class="mock-badge warning">Awaiting confirmation</span></td>
            <td>
                <a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="501">Details</a> |
                <a asp-area="Customer" asp-controller="Tickets" asp-action="Details" asp-route-id="506">Related ticket</a>
            </td>
        </tr>
        <tr>
            <td>Unit A-02</td>
            <td><a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="202">Oak Street 5</a></td>
            <td>1</td>
            <td><span class="mock-badge">Scheduled</span></td>
            <td>
                <a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="502">Details</a> |
                <a asp-area="Customer" asp-controller="Tickets" asp-action="Details" asp-route-id="505">Related ticket</a>
            </td>
        </tr>
        <tr>
            <td>Unit C-12</td>
            <td><a asp-area="Customer" asp-controller="Properties" asp-action="Details" asp-route-id="203">Harbor View 2</a></td>
            <td>1</td>
            <td><span class="mock-badge success">In Progress</span></td>
            <td>
                <a asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="503">Details</a> |
                <a asp-area="Customer" asp-controller="Tickets" asp-action="Details" asp-route-id="504">Related ticket</a>
            </td>
        </tr>
        </tbody>
    </table>

    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Properties" asp-action="Index">Open properties</a>
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Tickets" asp-action="Index">Open tickets</a>
    </div>
</section>

@{
    var propertyId = (int?)ViewData["PropertyId"] ?? 201;
    ViewData["Title"] = $"Property Details #{propertyId}";
}

<div class="mock-grid mock-grid-2">
    <section class="mock-card">
        <h2>Property profile</h2>
        <ul class="mock-link-list">
            <li>Name: Riverside 12</li>
            <li>Type: Apartment building</li>
            <li>Units in portfolio scope: 34</li>
            <li>Open tickets: 6</li>
        </ul>
    </section>
    <section class="mock-card">
        <h2>Customer visibility focus</h2>
        <p><span class="mock-badge warning">2 tickets awaiting confirmation</span></p>
        <p><span class="mock-badge">Next scheduled vendor visit: Tomorrow 13:30</span></p>
        <p class="mock-muted">Use this page to move from property-level status to unit-level context.</p>
    </section>
</div>

<section class="mock-card">
    <h2>Navigation and context links</h2>
    <div class="mock-actions">
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Units" asp-action="Index" asp-route-propertyId="@propertyId">Open units for this property</a>
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Units" asp-action="Details" asp-route-id="501">Open unit details</a>
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Tickets" asp-action="Details" asp-route-id="506">Open related ticket details</a>
        <a class="mock-btn ghost" asp-area="Customer" asp-controller="Properties" asp-action="Index">Back to properties</a>
    </div>
</section>

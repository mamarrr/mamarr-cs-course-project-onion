@model WebApp.ViewModels.Customer.CustomerProperties.PropertiesPageViewModel
@{
    Layout = "~/Views/Shared/_AppChromeLayout.cshtml";
}

@if (TempData["CustomerPropertiesSuccess"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

<div class="management-grid management-grid-2">
    <section class="management-card" style="grid-column: 1 / -1;">
        <h2 class="mb-3">@App.Resources.Views.UiText.Properties</h2>

        @if (Model.Properties.Count == 0)
        {
            <p class="management-muted mb-0">@T("NoPropertiesFound", "No properties found.")</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                    <tr>
                        <th>@App.Resources.Views.UiText.Name</th>
                        <th>@App.Resources.Views.UiText.AddressLine</th>
                        <th>@T("City", "City")</th>
                        <th>@T("PostalCode", "Postal code")</th>
                        <th>@T("PropertyType", "Property type")</th>
                        <th>@App.Resources.Views.UiText.Status</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var property in Model.Properties)
                    {
                        <tr>
                            <td>
                                <a asp-area="Property"
                                   asp-controller="Dashboard"
                                   asp-action="Index"
                                   asp-route-companySlug="@Model.CompanySlug"
                                   asp-route-customerSlug="@Model.CustomerSlug"
                                   asp-route-propertySlug="@property.PropertySlug">
                                    @property.PropertyName
                                </a>
                            </td>
                            <td>@property.AddressLine</td>
                            <td>@property.City</td>
                            <td>@property.PostalCode</td>
                            <td>@property.PropertyTypeLabel</td>
                            <td>
                                @if (property.IsActive)
                                {
                                    <span class="management-badge success">@T("Active", "Active")</span>
                                }
                                else
                                {
                                    <span class="management-badge">@T("Inactive", "Inactive")</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="management-card" style="grid-column: 1 / -1;">
        <h2 class="mb-3">@T("AddProperty", "Add property")</h2>

        <form asp-area="Customer"
              asp-controller="CustomerProperties"
              asp-action="Add"
              asp-route-companySlug="@Model.CompanySlug"
              asp-route-customerSlug="@Model.CustomerSlug"
              method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="AddProperty.Name" class="form-label"></label>
                    <input asp-for="AddProperty.Name" class="form-control" />
                    <span asp-validation-for="AddProperty.Name" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="AddProperty.PropertyTypeId" class="form-label"></label>
                    <select asp-for="AddProperty.PropertyTypeId" class="form-select">
                        <option value="">@T("SelectPropertyType", "Select property type")</option>
                        @foreach (var option in Model.PropertyTypeOptions)
                        {
                            <option value="@option.Id">@option.Label</option>
                        }
                    </select>
                    <span asp-validation-for="AddProperty.PropertyTypeId" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="AddProperty.AddressLine" class="form-label"></label>
                    <input asp-for="AddProperty.AddressLine" class="form-control" />
                    <span asp-validation-for="AddProperty.AddressLine" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="AddProperty.PostalCode" class="form-label"></label>
                    <input asp-for="AddProperty.PostalCode" class="form-control" />
                    <span asp-validation-for="AddProperty.PostalCode" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="AddProperty.City" class="form-label"></label>
                    <input asp-for="AddProperty.City" class="form-control" />
                    <span asp-validation-for="AddProperty.City" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="AddProperty.Notes" class="form-label"></label>
                    <textarea asp-for="AddProperty.Notes" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="AddProperty.Notes" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="AddProperty.IsActive" class="form-check-input" />
                        <label asp-for="AddProperty.IsActive" class="form-check-label"></label>
                    </div>
                </div>

                <div class="col-12">
                    <button type="submit" class="management-btn primary">@T("AddProperty", "Add property")</button>
                </div>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@functions {
    private static string T(string key, string fallback)
    {
        return App.Resources.Views.UiText.ResourceManager.GetString(key) ?? fallback;
    }
}
